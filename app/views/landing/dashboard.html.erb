<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Panel de Control - Reply-AI</title>
</head>
<body class="bg-gray-50 text-gray-900 font-sans">
    <div class="flex min-h-screen">
        <aside class="w-64 bg-blue-700 text-white p-6">
            <h1 class="text-2xl font-black mb-10 text-white">Reply-AI</h1>
            <nav class="space-y-4">
                <a href="<%= reply_ai_dashboard_path %>" class="block font-bold bg-blue-800 p-3 rounded-lg text-white">⚙️ Configuración Bot</a>              
                <!-- El enlace ahora usa la URL de SSO generada en el controlador -->
                <a href="<%= @magic_link_to_chats %>" id="btn-to-chats" class="block font-medium hover:bg-blue-600 p-3 rounded-lg transition text-white">
                    💬 Ir a mis Chats
                </a>
            </nav>
        </aside>

        <main class="flex-1 p-10 overflow-y-auto">
            <header class="flex justify-between items-center mb-10">
                <h2 class="text-3xl font-bold">Configuración de Inteligencia Artificial</h2>
                <% if flash[:notice] %>
                    <div class="bg-green-100 text-green-700 px-4 py-2 rounded-lg border border-green-200"><%= flash[:notice] %></div>
                <% end %>
            </header>

            <form action="/dashboard/update" method="POST" class="max-w-4xl space-y-8">
                <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                
                <!-- (Aquí va el resto de tu formulario de Prompts y Delay...) -->
                
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between mb-8">
                    <div>
                        <h3 class="font-bold text-lg text-gray-800">Estado del Asistente IA</h3>
                        <p class="text-sm text-gray-500">Cuando está activo, el bot responderá automáticamente.</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" name="chat_gpt_enabled" value="1" <%= 'checked' if @bot_enabled %> class="sr-only peer">
                        <div class="w-14 h-7 bg-gray-200 rounded-full peer peer-checked:bg-green-500 after:content-[''] after:absolute after:top-0.5 after:left-[4px] after:bg-white after:rounded-full after:h-6 after:w-6 after:transition-all"></div>
                    </label>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 space-y-6">
                    <h3 class="font-bold text-lg mb-4 text-gray-800">Entrenamiento de la IA</h3>
                    <% [['condicionProducto', 'Condición'], ['envios', 'Envíos'], ['garantia', 'Garantía'], ['mediosPago', 'Pagos']].each do |field, label| %>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2"><%= label %></label>
                            <textarea name="prompts[<%= field %>]" rows="3" class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500"><%= @prompts[field] %></textarea>
                        </div>
                    <% end %>
                </div>

                <button type="submit" class="bg-blue-600 text-white px-10 py-4 rounded-2xl font-black shadow-lg hover:bg-blue-700 transition">
                    Guardar Cambios
                </button>
            </form>
        </main>
    </div>
</body>
</html>