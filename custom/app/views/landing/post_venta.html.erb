                    </svg>
                    <svg id="icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/>
                    </svg>
                </button>
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0"
                     style="background:#fd5101">U</div>
            </div>
        </header>

        <!-- Contenido -->
        <main class="flex-1 overflow-y-auto px-4 py-5 sm:px-8 sm:py-7">
            <form action="<%= update_post_venta_path %>" method="POST" class="space-y-6">
                <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

                <!-- Toggle maestro + modelo -->
                <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                    <div class="px-4 sm:px-6 py-5 border-b border-gray-50">
                        <div class="flex items-center justify-between flex-wrap gap-3">
                            <div>
                                <h3 class="font-semibold text-gray-800 text-lg">Agente IA Post-Venta</h3>
                                <p class="text-[13px] text-gray-400 mt-0.5">Respondé automáticamente los mensajes de compradores con pedidos en curso.</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                                <input type="checkbox" name="post_venta_ia[enabled]" value="1"
                                       id="pv-ia-toggle"
                                       <%= @pv_ia['enabled'] != false ? 'checked' : '' %>
                                       class="sr-only peer"
                                       onchange="document.getElementById('pv-ia-fields').classList.toggle('hidden', !this.checked)">
                                <div class="w-12 h-6 bg-gray-200 rounded-full peer
                                            peer-checked:bg-[#fd5101]
                                            after:content-[''] after:absolute after:top-0.5 after:left-[3px]
                                            after:bg-white after:rounded-full after:h-5 after:w-5
                                            after:transition-all peer-checked:after:translate-x-6
                                            after:shadow-sm"></div>
                            </label>
                        </div>
                    </div>

                    <div id="pv-ia-fields" class="<%= @pv_ia['enabled'] == false ? 'hidden' : '' %>">
                        <!-- Modelo -->
                        <div class="px-4 sm:px-6 py-5 border-b border-gray-50">
                            <label class="block text-xs font-bold text-gray-500 mb-1 uppercase tracking-widest">Modelo OpenAI</label>
                            <p class="text-[13px] text-gray-400 mb-3">
                                <code class="text-xs bg-gray-100 px-1 py-0.5 rounded">gpt-4o-mini</code> es más rápido y económico.
                                <code class="text-xs bg-gray-100 px-1 py-0.5 rounded">gpt-4o</code> da respuestas de mayor calidad para consultas complejas.
                            </p>
                            <div class="flex gap-4">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="post_venta_ia[model]" value="gpt-4o-mini"
                                           <%= (@pv_ia['model'] || 'gpt-4o-mini') == 'gpt-4o-mini' ? 'checked' : '' %>
                                           class="accent-[#fd5101]">
                                    <span class="text-sm text-gray-700 font-medium">gpt-4o-mini <span class="text-xs text-gray-400">(recomendado)</span></span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="post_venta_ia[model]" value="gpt-4o"
                                           <%= @pv_ia['model'] == 'gpt-4o' ? 'checked' : '' %>
                                           class="accent-[#fd5101]">
                                    <span class="text-sm text-gray-700 font-medium">gpt-4o</span>
                                </label>
                            </div>
                        </div>

                        <!-- Tono general -->
                        <div class="px-4 sm:px-6 py-5 border-b border-gray-50">
                            <label class="block text-xs font-bold text-gray-500 mb-1 uppercase tracking-widest">Tono e identidad del agente</label>
                            <p class="text-[13px] text-gray-400 mb-2">Describe cómo debe hablar el agente. Aplica a todas las ramas. Ej: <em>"Usar usted, tono formal, no usar emojis."</em></p>
                            <textarea name="post_venta_ia[prompts][tono]" rows="2"
                                placeholder="Ej: Usá un tono amigable y cercano, en español argentino. Dirigite siempre al cliente como 'vos'."
                                class="w-full p-3 bg-gray-50 border border-gray-200 rounded-xl focus-brand text-[14px] leading-relaxed resize-none transition hover:border-gray-300"><%= @pv_ia.dig('prompts', 'tono') %></textarea>
                        </div>

                        <!-- Intenciones -->
                        <div class="px-4 sm:px-6 py-5 space-y-5">
                            <p class="text-xs font-bold text-gray-500 uppercase tracking-widest">Comportamiento por tipo de consulta</p>

                            <!-- Logística -->
                            <div class="rounded-xl border border-gray-100 overflow-hidden">
                                <div class="px-4 py-3 intent-head-blue flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="text-base">🚚</span>
                                        <span class="font-semibold text-gray-800 text-sm">Logística</span>
                                        <span class="text-[12px] text-gray-400">tracking, envío, demoras</span>
                                    </div>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[logistica][enabled]" value="1"
                                               <%= @pv_ia.dig('logistica', 'enabled') != false ? 'checked' : '' %>
                                               class="sr-only peer"
                                               onchange="document.getElementById('pv-logistica-prompt').classList.toggle('hidden', !this.checked)">
                                        <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-[#fd5101] after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5 after:shadow-sm"></div>
                                    </label>
                                </div>
                                <div id="pv-logistica-prompt" class="px-4 py-3 <%= @pv_ia.dig('logistica', 'enabled') == false ? 'hidden' : '' %>">
                                    <label class="block text-xs text-gray-500 mb-1">Instrucciones adicionales para respuestas de envío</label>
                                    <textarea name="post_venta_ia[prompts][logistica]" rows="2"
                                        placeholder="Ej: Nuestros envíos demoran 2-5 días hábiles. No prometas fechas exactas."
                                        class="w-full p-2.5 bg-gray-50 border border-gray-200 rounded-lg focus-brand text-[13px] resize-none transition hover:border-gray-300"><%= @pv_ia.dig('prompts', 'logistica') %></textarea>
                                </div>
                            </div>

                            <!-- Soporte -->
                            <div class="rounded-xl border border-gray-100 overflow-hidden">
                                <div class="px-4 py-3 intent-head-purple flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="text-base">🔧</span>
                                        <span class="font-semibold text-gray-800 text-sm">Soporte técnico</span>
                                        <span class="text-[12px] text-gray-400">instrucciones, compatibilidad</span>
                                    </div>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[soporte][enabled]" value="1"
                                               <%= @pv_ia.dig('soporte', 'enabled') != false ? 'checked' : '' %>
                                               class="sr-only peer"
                                               onchange="document.getElementById('pv-soporte-fields').classList.toggle('hidden', !this.checked)">
                                        <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-[#fd5101] after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5 after:shadow-sm"></div>
                                    </label>
                                </div>
                                <div id="pv-soporte-fields" class="px-4 py-3 space-y-3 <%= @pv_ia.dig('soporte', 'enabled') == false ? 'hidden' : '' %>">
                                    <div>
                                        <label class="block text-xs text-gray-500 mb-1">Instrucciones adicionales para soporte</label>
                                        <textarea name="post_venta_ia[prompts][soporte]" rows="2"
                                            placeholder="Ej: El producto tiene 1 año de garantía. Para reclamos, pedí foto del defecto."
                                            class="w-full p-2.5 bg-gray-50 border border-gray-200 rounded-lg focus-brand text-[13px] resize-none transition hover:border-gray-300"><%= @pv_ia.dig('prompts', 'soporte') %></textarea>
                                    </div>
                                    <label class="flex items-center gap-2.5 cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[soporte][fallback_to_human]" value="1"
                                               <%= @pv_ia.dig('soporte', 'fallback_to_human') != false ? 'checked' : '' %>
                                               class="w-4 h-4 rounded accent-[#fd5101]">
                                        <span class="text-[13px] text-gray-700">Si la IA no encuentra solución, asignar automáticamente a agente humano (<code class="text-xs bg-gray-100 px-1 rounded">atencion-humana</code>)</span>
                                    </label>
                                </div>
                            </div>

                            <!-- Reclamo -->
                            <div class="rounded-xl border border-gray-100 overflow-hidden">
                                <div class="px-4 py-3 intent-head-red flex items-center">
                                    <div class="flex items-center gap-2">
                                        <span class="text-base">⚠️</span>
                                        <span class="font-semibold text-gray-800 text-sm">Reclamo</span>
                                        <span class="text-[12px] text-gray-400">daño, devolución, queja — siempre escala a humano</span>
                                    </div>
                                </div>
                                <div class="px-4 py-3 space-y-3">
                                    <label class="flex items-center gap-2.5 cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[reclamo][notify_customer]" value="1"
                                               <%= @pv_ia.dig('reclamo', 'notify_customer') ? 'checked' : '' %>
                                               class="w-4 h-4 rounded accent-[#fd5101]"
                                               onchange="document.getElementById('pv-escalacion-prompt').classList.toggle('hidden', !this.checked)">
                                        <span class="text-[13px] text-gray-700">Avisar al comprador que un especialista lo va a atender</span>
                                    </label>
                                    <div id="pv-escalacion-prompt" class="<%= @pv_ia.dig('reclamo', 'notify_customer') ? '' : 'hidden' %>">
                                        <label class="block text-xs text-gray-500 mb-1">Mensaje visible al cliente al escalar</label>
                                        <textarea name="post_venta_ia[prompts][escalacion]" rows="2"
                                            placeholder="Ej: Lamentamos el inconveniente. Un especialista de nuestro equipo te va a contactar en menos de 24hs."
                                            class="w-full p-2.5 bg-gray-50 border border-gray-200 rounded-lg focus-brand text-[13px] resize-none transition hover:border-gray-300"><%= @pv_ia.dig('prompts', 'escalacion') %></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Cierre -->
                            <div class="rounded-xl border border-gray-100 overflow-hidden">
                                <div class="px-4 py-3 intent-head-green flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="text-base">✅</span>
                                        <span class="font-semibold text-gray-800 text-sm">Cierre</span>
                                        <span class="text-[12px] text-gray-400">agradecimiento, todo bien, despedida</span>
                                    </div>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[cierre][enabled]" value="1"
                                               <%= @pv_ia.dig('cierre', 'enabled') != false ? 'checked' : '' %>
                                               class="sr-only peer"
                                               onchange="document.getElementById('pv-cierre-fields').classList.toggle('hidden', !this.checked)">
                                        <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-[#fd5101] after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5 after:shadow-sm"></div>
                                    </label>
                                </div>
                                <div id="pv-cierre-fields" class="px-4 py-3 space-y-3 <%= @pv_ia.dig('cierre', 'enabled') == false ? 'hidden' : '' %>">
                                    <div>
                                        <label class="block text-xs text-gray-500 mb-1">Instrucciones para el mensaje de despedida</label>
                                        <textarea name="post_venta_ia[prompts][cierre]" rows="2"
                                            placeholder="Ej: Invitá siempre a seguirnos en Instagram @tienda y a dejar una reseña en ML."
                                            class="w-full p-2.5 bg-gray-50 border border-gray-200 rounded-lg focus-brand text-[13px] resize-none transition hover:border-gray-300"><%= @pv_ia.dig('prompts', 'cierre') %></textarea>
                                    </div>
                                    <label class="flex items-center gap-2.5 cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[cierre][auto_resolve]" value="1"
                                               <%= @pv_ia.dig('cierre', 'auto_resolve') != false ? 'checked' : '' %>
                                               class="w-4 h-4 rounded accent-[#fd5101]">
                                        <span class="text-[13px] text-gray-700">Resolver conversación automáticamente al detectar cierre</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Botón guardar -->
                <div class="flex justify-end pb-8">
                    <button type="submit"
                            class="px-6 py-2.5 rounded-xl text-sm font-bold text-white transition-colors"
                            style="background:#fd5101">
                        Guardar cambios
                    </button>
                </div>
            </form>
        </main>
    </div>
</div>

<script>
    /* ── Sidebar anti-FOUC ─── */
    (function() {
        if (window.innerWidth >= 768 && localStorage.getItem('replyai_sidebar_collapsed') === '1') {
            const sb = document.getElementById('sidebar');
            if (sb) {
                sb.classList.add('collapsed');
                document.getElementById('sb-chevron-left')?.classList.add('hidden');
                document.getElementById('sb-chevron-right')?.classList.remove('hidden');
            }
        }
    })();

    function toggleSidebar() {
        const sb = document.getElementById('sidebar');
        if (!sb) return;
        const isCollapsed = sb.classList.toggle('collapsed');
        document.getElementById('sb-chevron-left')?.classList.toggle('hidden', isCollapsed);
        document.getElementById('sb-chevron-right')?.classList.toggle('hidden', !isCollapsed);
        localStorage.setItem('replyai_sidebar_collapsed', isCollapsed ? '1' : '');
    }

    function openSidebar() {
        const sb = document.getElementById('sidebar');
        const ov = document.getElementById('sidebar-overlay');
        if (!sb) return;
        sb.classList.add('mobile-open');
        if (ov) ov.classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
        const sb = document.getElementById('sidebar');
        const ov = document.getElementById('sidebar-overlay');
        if (!sb) return;
        sb.classList.remove('mobile-open');
        if (ov) ov.classList.remove('active');
        document.body.style.overflow = '';
    }

    window.addEventListener('resize', function() {
        if (window.innerWidth >= 768) closeSidebar();
    });

    /* ── Dark mode ─── */
    function applyThemeIcons() {
        const dark = document.documentElement.classList.contains('dark');
        document.getElementById('icon-sun').classList.toggle('hidden', !dark);
        document.getElementById('icon-moon').classList.toggle('hidden', dark);
    }

    function toggleDarkMode() {
        const dark = document.documentElement.classList.contains('dark');
        document.documentElement.classList.toggle('dark', !dark);
        document.documentElement.classList.toggle('light', dark);
        localStorage.setItem('replyai_theme', dark ? 'light' : 'dark');
        applyThemeIcons();
    }

    applyThemeIcons();
</script>
</body>
</html>
