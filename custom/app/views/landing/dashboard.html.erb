        document.querySelectorAll('.pv-rag-tab').forEach(btn => {
            btn.classList.remove('border-[#fd5101]', 'text-[#fd5101]', 'font-semibold');
            btn.style.borderBottomColor = '';
            btn.style.color = '';
        });
        const target = document.getElementById(tabId);
        if (target) target.classList.remove('hidden');
        if (event && event.currentTarget) {
            event.currentTarget.style.borderBottomColor = '#fd5101';
            event.currentTarget.style.color = '#fd5101';
        }
    }

    function switchPvRagById(id) {
