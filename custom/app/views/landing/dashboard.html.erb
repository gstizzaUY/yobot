                <svg class="w-8 h-8 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>
                <p class="text-xs text-gray-400 mb-3">PDF, DOCX, TXT — máx. 10 MB</p>
                <input type="file" name="file" required
                    class="block w-full text-xs text-gray-500
                           file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0
