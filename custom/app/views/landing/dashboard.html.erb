    // Inicializar onboarding al cargar
    initOnboarding();

    function openModal(id, level, title) {
        document.getElementById('m-ref').value   = id;
        document.getElementById('m-level').value = level;
        document.getElementById('m-title').innerText = 'Entrenar: ' + title;
        document.getElementById('modal-upload').classList.replace('hidden', 'flex');
    }

    function closeModal() {
        document.getElementById('modal-upload').classList.replace('flex', 'hidden');
    }

    // ── Post-venta RAG modal ──────────────────────────────────────
    function pvOpenModal(id, level, title) {
        document.getElementById('pv-m-ref').value   = id;
        document.getElementById('pv-m-level').value = level;
        document.getElementById('pv-m-title').innerText = 'Entrenar PV: ' + title;
        document.getElementById('modal-pv-upload').classList.replace('hidden', 'flex');
