    // ── Gestión de documentos RAG (modal AJAX) ──────────────────────────
    function openMgrModal(referenceId, mode, title) {
        document.getElementById('mgr-mode-label').textContent = mode === 'pv' ? 'Post-venta' : 'Pre-venta';
        document.getElementById('mgr-title').textContent      = title;
        document.getElementById('mgr-ref-id').textContent     = referenceId;
        document.getElementById('mgr-body').innerHTML         = '<div class="flex items-center justify-center py-10 text-sm text-gray-400">Cargando…</div>';
        document.getElementById('modal-docs-manager').classList.replace('hidden', 'flex');

        const url = '/dashboard/docs?mode=' + encodeURIComponent(mode) +
                    '&reference_id=' + encodeURIComponent(referenceId) +
                    '&title=' + encodeURIComponent(title);
        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => r.text())
            .then(html => { document.getElementById('mgr-body').innerHTML = html; })
            .catch(() => { document.getElementById('mgr-body').innerHTML = '<p class="text-sm text-red-400 py-6 text-center">Error al cargar los documentos.</p>'; });
    }

    function closeMgrModal() {
        document.getElementById('modal-docs-manager').classList.replace('flex', 'hidden');
    }

    function mgrSwitchTab(tab) {
        const panels = { bulk: 'mgr-panel-bulk', manual: 'mgr-panel-manual' };
        const tabs   = { bulk: 'mgr-tab-bulk',   manual: 'mgr-tab-manual' };
        Object.entries(panels).forEach(([key, id]) => {
            const panel = document.getElementById(id);
            if (panel) panel.classList.toggle('hidden', key !== tab);
        });
        Object.entries(tabs).forEach(([key, id]) => {
            const btn = document.getElementById(id);
            if (!btn) return;
            if (key === tab) {
                btn.classList.add('border-[#fd5101]', 'text-[#fd5101]');
                btn.classList.remove('border-transparent', 'text-gray-400');
            } else {
                btn.classList.remove('border-[#fd5101]', 'text-[#fd5101]');
                btn.classList.add('border-transparent', 'text-gray-400');
            }
        });
    }

    function deleteDocAjax(docId, mode, path) {
        if (!confirm('¿Eliminar este documento del RAG?')) return;
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content
                       || '<%= form_authenticity_token %>';
        fetch(path, {
            method: 'DELETE',
            headers: { 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.ok) {
                const el = document.getElementById('doc-item-' + docId);
                if (el) el.remove();
                // Actualizar contador en la fila del producto
                const refId = document.getElementById('mgr-ref-id').textContent;
                refreshDocRowBadge(refId, mode);
            } else {
                alert('Error: ' + (data.error || 'No se pudo eliminar'));
            }
        })
        .catch(() => alert('Error de red al eliminar.'));
    }

    function refreshDocRowBadge(referenceId, mode) {
        // Recarga el contador visualmente después de un delete
        const url = '/dashboard/docs?mode=' + encodeURIComponent(mode) +
                    '&reference_id=' + encodeURIComponent(referenceId) +
                    '&title=' + encodeURIComponent(document.getElementById('mgr-title').textContent);
        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => r.text())
            .then(html => { document.getElementById('mgr-body').innerHTML = html; });
    }
