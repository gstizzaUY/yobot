<!-- ═══════════════ MODAL GESTIÓN DE DOCUMENTOS ═══════════════ -->
<div id="modal-docs-manager" class="fixed inset-0 bg-gray-900/50 hidden items-center justify-center backdrop-blur-sm z-50 p-4">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-xl flex flex-col" style="max-height:85vh">
        <!-- Header -->
        <div class="flex items-start justify-between gap-3 px-6 pt-6 pb-4 border-b border-gray-100 flex-shrink-0">
            <div class="min-w-0">
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-0.5" id="mgr-mode-label"></p>
                <h3 class="text-base font-black text-gray-900 leading-tight line-clamp-2" id="mgr-title"></h3>
                <p class="text-xs text-gray-400 font-mono mt-0.5" id="mgr-ref-id"></p>
            </div>
            <button onclick="closeMgrModal()" class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full text-gray-400 hover:bg-gray-100 transition text-xl leading-none">&times;</button>
        </div>
        <!-- Body: cargado via AJAX -->
        <div class="flex-1 overflow-y-auto px-6 py-4" id="mgr-body">
            <div class="flex items-center justify-center py-10 text-sm text-gray-400">Cargando…</div>
        </div>
    </div>
</div>

<script>
    // ===================== POLLING DE SINCRONIZACIÓN =====================
    <% if @is_syncing %>
    (function() {
        const ACCOUNT_ID = '<%= @account.id %>';
        const STATUS_URL = '/dashboard/status?account_id=' + ACCOUNT_ID;
        let pollCount    = 0;

        function updateBanner(total, totalCats) {
            const el = document.getElementById('sync-count');
            if (el) {
                const parts = [];
                if (total > 0)     parts.push(total + ' productos');
                if (totalCats > 0) parts.push(totalCats + ' categorías');
                el.textContent = parts.length ? parts.join(' · ') + ' importados...' : 'Iniciando importación...';
            }
        }

        function poll() {
            fetch(STATUS_URL, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.json())
                .then(data => {
                    updateBanner(data.total_products, data.total_categories);
                    if (!data.syncing) {
                        window.location.href = '<%= reply_ai_dashboard_path(panel: "panel-pv-docs") %>' + '&account_id=<%= @account.id %>';
                    } else {
                        pollCount++;
                        const delay = Math.min(3000 + pollCount * 300, 8000);
                        setTimeout(poll, delay);
                    }
                })
                .catch(() => setTimeout(poll, 8000));
        }

        setTimeout(poll, 3000);
    })();
    <% end %>

    const BRAND        = '#fd5101';
    const BRAND_BORDER = '#fd5101';

    /* ── Sidebar colapsable ─────────────────────────────────── */
    (function() {
        // Anti-FOUC: aplicar estado guardado antes del primer render
        if (window.innerWidth >= 768 && localStorage.getItem('replyai_sidebar_collapsed') === '1') {
            const sb = document.getElementById('sidebar');
            if (sb) {
                sb.classList.add('collapsed');
                const chevL = document.getElementById('sb-chevron-left');
                const chevR = document.getElementById('sb-chevron-right');
                if (chevL) chevL.classList.add('hidden');
                if (chevR) chevR.classList.remove('hidden');
            }
        }
    })();

    function toggleSidebar() {
        // Desktop: colapsar / expandir (iconos vs texto)
        const sb = document.getElementById('sidebar');
        if (!sb) return;
        const isCollapsed = sb.classList.toggle('collapsed');
        document.getElementById('sb-chevron-left')?.classList.toggle('hidden', isCollapsed);
        document.getElementById('sb-chevron-right')?.classList.toggle('hidden', !isCollapsed);
        localStorage.setItem('replyai_sidebar_collapsed', isCollapsed ? '1' : '');
    }

    function openSidebar() {
        // Mobile: slide-in como drawer
        const sb  = document.getElementById('sidebar');
        const ov  = document.getElementById('sidebar-overlay');
        if (!sb) return;
        sb.classList.add('mobile-open');
        if (ov) ov.classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
        const sb  = document.getElementById('sidebar');
        const ov  = document.getElementById('sidebar-overlay');
        if (!sb) return;
        sb.classList.remove('mobile-open');
        if (ov) ov.classList.remove('active');
        document.body.style.overflow = '';
    }

    // Cerrar drawer si se redimensiona a desktop
    window.addEventListener('resize', function() {
        if (window.innerWidth >= 768) closeSidebar();
    });
    /* ─────────────────────────────────────────────────────────── */

    // ── Panel navigation ──────────────────────────────────────────
    function showPanel(panelId) {
        document.querySelectorAll('.main-content').forEach(c => c.classList.add('hidden'));
        const el = document.getElementById(panelId);
        if (el) el.classList.remove('hidden');
        document.querySelectorAll('.sidebar-link').forEach(link => {
            const active = link.dataset.panel === panelId;
            link.style.background = active ? 'rgba(253,81,1,0.15)' : '';
            link.style.color      = active ? '#fd5101' : '';
            link.style.fontWeight = active ? '700' : '';
        });
        const titles = {
            'panel-pv-ajustes':        'Ajustes del bot — Pre-venta',
            'panel-pv-instrucciones':  'Instrucciones — Pre-venta',
            'panel-pv-docs':           'Documentos',
            'panel-pv-saludos':        'Saludos',
            'panel-postventa-ajustes': 'Ajustes del bot — Post-venta',
            'panel-postventa-prompts': 'Prompts — Post-venta',
            'panel-postventa-docs':    'Documentos — Post-venta',
        };
        const h2 = document.querySelector('#page-title h2');
        if (h2 && titles[panelId]) h2.textContent = titles[panelId];
        history.replaceState(null, '', '?panel=' + panelId);
    }

    function toggleChannel(name) {
        const items   = document.getElementById('channel-' + name + '-items');
        const chevron = document.getElementById(name + '-chevron');
        if (!items) return;
        const hidden = items.classList.toggle('hidden');
        if (chevron) chevron.style.transform = hidden ? 'rotate(-90deg)' : '';
    }

    // Activar panel por parámetro URL (o default panel-pv-ajustes)
    (function() {
        const p     = new URLSearchParams(location.search);
        const panel = p.get('panel');
        const tab   = p.get('tab'); // backward compat
        if (panel) {
            showPanel(panel);
            if (panel === 'panel-pv-docs') switchRagById('rag-global');
            if (panel === 'panel-postventa-docs') switchPvRagById('pv-rag-global');
        } else if (tab === 'prods')    { showPanel('panel-pv-docs'); switchRagById('rag-prods'); }
        else if (tab === 'pv-prods')   { showPanel('panel-postventa-docs'); switchPvRagById('pv-rag-prods'); }
        else if (tab === 'cats')    { showPanel('panel-pv-docs'); switchRagById('rag-cats'); }
        else if (tab === 'rag')     { showPanel('panel-pv-docs'); switchRagById('rag-global'); }
        else                        { showPanel('panel-pv-ajustes'); }
    })();

    // ── Dark mode ────────────────────────────────────────
    function isDarkMode() {
        return document.documentElement.classList.contains('dark');
    }

    function activeBg() {
        return isDarkMode() ? '#2e3340' : '#fff';
    }

    function activeTabShadow() {
        return isDarkMode() ? 'none' : '0 1px 3px rgba(0,0,0,.08)';
    }

    function applyThemeIcons() {
        const dark = isDarkMode();
        document.getElementById('icon-sun').classList.toggle('hidden', !dark);
        document.getElementById('icon-moon').classList.toggle('hidden', dark);
    }

    function toggleDarkMode() {
        const dark = isDarkMode();
        const html = document.documentElement;
        html.classList.toggle('dark', !dark);
        html.classList.toggle('light', dark);
        localStorage.setItem('replyai_theme', dark ? 'light' : 'dark');
        applyThemeIcons();
    }

    // Aplicar íconos al cargar
    applyThemeIcons();

    function switchMainById(panelId) { showPanel(panelId); }

    function switchRagById(tabId) {
        document.querySelectorAll('.rag-content').forEach(c => c.classList.add('hidden'));
        const el = document.getElementById(tabId);
        if (el) el.classList.remove('hidden');
        const map  = { 'rag-global': 0, 'rag-cats': 1, 'rag-prods': 2 };
        document.querySelectorAll('.rag-tab').forEach((btn, i) => {
            const active = map[tabId] === i;
            btn.style.color        = active ? BRAND : '';
            btn.style.borderColor  = active ? BRAND_BORDER : 'transparent';
            btn.style.fontWeight   = active ? '700' : '';
            btn.classList.toggle('text-gray-500', !active);
        });
    }



    function switchRag(evt, tabId) {
        document.querySelectorAll('.rag-content').forEach(c => c.classList.add('hidden'));
        document.getElementById(tabId).classList.remove('hidden');
        document.querySelectorAll('.rag-tab').forEach(btn => {
            btn.style.color       = '';
            btn.style.borderColor = 'transparent';
            btn.style.fontWeight  = '';
            btn.classList.add('text-gray-500');
        });
        evt.currentTarget.style.color       = BRAND;
        evt.currentTarget.style.borderColor = BRAND_BORDER;
        evt.currentTarget.style.fontWeight  = '700';
        evt.currentTarget.classList.remove('text-gray-500');
    }

    // ===================== ONBOARDING =====================
    let obCurrentSlide = 1;
    const OB_TOTAL = 5;

    function initOnboarding() {
        // Si ya fue visto, no mostrar
        if (localStorage.getItem('replyai_onboarding_seen')) return;
        // Si el checklist fue ocultado manualmente, no mostrar el modal tampoco
        if (localStorage.getItem('replyai_checklist_hidden')) return;
        // Mostrar con un pequeño delay para que no sea abrupto
        setTimeout(showOnboarding, 600);
    }

    function showOnboarding() {
        document.getElementById('modal-onboarding').classList.replace('hidden', 'flex');
        goToSlide(1);
    }

    function closeOnboarding() {
        document.getElementById('modal-onboarding').classList.replace('flex', 'hidden');
        localStorage.setItem('replyai_onboarding_seen', '1');
    }

    function goToSlide(n) {
        obCurrentSlide = n;
        document.querySelectorAll('.ob-slide').forEach((s, i) => {
            s.classList.toggle('active', i + 1 === n);
        });
        // Dots
        document.querySelectorAll('.ob-dot').forEach((d, i) => {
            d.classList.toggle('active', i + 1 === n);
        });
        // Progress bar
        document.getElementById('ob-modal-bar').style.width = (n / OB_TOTAL * 100) + '%';
        // Botones
        document.getElementById('ob-prev').classList.toggle('hidden', n === 1);
        document.getElementById('ob-next').classList.toggle('hidden', n === OB_TOTAL);
        document.getElementById('ob-done').classList.toggle('hidden', n !== OB_TOTAL);
        // Texto del botón siguiente
        const nextBtn = document.getElementById('ob-next');
        nextBtn.textContent = n === 1 ? 'Empezar →' : 'Siguiente →';
    }

    function obNext() {
        if (obCurrentSlide < OB_TOTAL) goToSlide(obCurrentSlide + 1);
    }

    function obPrev() {
        if (obCurrentSlide > 1) goToSlide(obCurrentSlide - 1);
    }

    // ── Checklist helpers ──
    function hideChecklist() {
        const el = document.getElementById('onboarding-checklist');
        if (el) el.style.display = 'none';
        localStorage.setItem('replyai_checklist_hidden', '1');
    }

    // Aplica visibilidad del checklist según localStorage
    (function() {
        if (localStorage.getItem('replyai_checklist_hidden')) {
            const el = document.getElementById('onboarding-checklist');
            if (el) el.style.display = 'none';
        }
        // Marcar pasos 3 y 4 como done si el usuario los marcó manualmente
        ['ob-step-rag', 'ob-step-prods'].forEach(id => {
            if (localStorage.getItem('replyai_done_' + id)) {
                const el = document.getElementById(id);
                if (el) el.classList.add('ob-step-done');
                // Actualizar ícono
                const iconEl = el.querySelector('.ob-step-icon');
                if (iconEl) {
                    iconEl.classList.remove('bg-orange-50','border-orange-200','text-[#fd5101]');
                    iconEl.classList.add('bg-green-50','border-green-200','text-green-600');
                    iconEl.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';
                }
                const labelEl = el.querySelector('.ob-step-label');
                if (labelEl) labelEl.style.textDecoration = 'line-through';
                const linkEl = el.querySelector('button');
                if (linkEl) linkEl.style.display = 'none';
                recalcProgress();
            }
        });
    })();

    function recalcProgress() {
        const steps = document.querySelectorAll('.ob-step');
        const done  = document.querySelectorAll('.ob-step.ob-step-done').length;
        const lbl   = document.getElementById('ob-progress-label');
        const bar   = document.getElementById('ob-progress-bar');
        if (lbl) lbl.textContent = done + '/4 completados';
        if (bar) bar.style.width = (done * 25) + '%';
    }

    function markStepDone(stepId) {
        localStorage.setItem('replyai_done_' + stepId, '1');
        const el = document.getElementById(stepId);
        if (!el) return;
        el.classList.add('ob-step-done');
        const iconEl = el.querySelector('.ob-step-icon');
        if (iconEl) {
            iconEl.className = 'ob-step-icon w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 border-2 mt-0.5 bg-green-50 border-green-200 text-green-600';
            iconEl.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';
        }
        const linkEl = el.querySelector('button');
        if (linkEl) linkEl.style.display = 'none';
        recalcProgress();
    }

