    <!-- ═══════════════ CONTENIDO PRINCIPAL ═══════════════ -->
    <div class="flex-1 flex flex-col overflow-hidden">

        <!-- Topbar -->
        <header id="topbar" class="flex-shrink-0 h-16 bg-white border-b border-gray-100 flex items-center justify-between px-4 transition-colors duration-200">
            <div class="flex items-center gap-2">
                <!-- Hamburguesa mobile -->
                <button id="sidebar-toggle-mobile" onclick="openSidebar()"
                        class="w-9 h-9 flex items-center justify-center rounded-xl text-gray-500 hover:bg-gray-100 transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
                </button>
                <div id="page-title" class="flex items-center gap-3">
                    <h2 class="text-xl font-semibold text-gray-900">Prompts</h2>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <% if flash[:notice] %>
                    <div class="flex items-center gap-1.5 bg-green-50 text-green-700 px-3 py-1.5 rounded-lg border border-green-100 text-sm font-medium">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <%= flash[:notice] %>
                    </div>
                <% end %>

                <!-- Toggle dark / light mode -->
                <button id="theme-toggle" onclick="toggleDarkMode()"
                        class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-500 hover:bg-gray-100 transition-colors"
                        title="Cambiar tema">
                    <!-- Sol: visible en dark mode -->
                    <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
                    </svg>
                    <!-- Luna: visible en light mode -->
                    <svg id="icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/>
                    </svg>
                </button>

                <!-- Avatar (reemplazá 'U' con inicial del usuario) -->
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0"
                     style="background:#fd5101">U</div>
            </div>
        </header>

        <!-- Área de scroll del contenido -->
        <main class="flex-1 overflow-y-auto px-4 py-5 sm:px-8 sm:py-7">

            <!-- ══════ CHECKLIST PRIMEROS PASOS ══════ -->
            <%
                ob_step1 = @bot_enabled
                ob_step2 = @prompts['saludoGeneral'].present?
                ob_all_done = ob_step1 && ob_step2
            %>
            <div id="onboarding-checklist"
                 class="mb-6 bg-white rounded-2xl border border-gray-100 overflow-hidden"
                 style="<%= ob_all_done ? 'display:none' : '' %>">

                <!-- Cabecera del banner -->
                <div id="ob-checklist-header" class="px-4 sm:px-6 py-4 border-b border-gray-100 flex flex-wrap items-center justify-between gap-3"
                     style="background:linear-gradient(135deg,#fff4ef 0%,#fff 60%)">
                    <div class="flex items-center gap-3">
                        <!-- Icono cohete -->
                        <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0"
                             style="background:#fd5101">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.82m5.84-2.56a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.82m2.56-5.84a14.926 14.926 0 01-2.58 5.841m0 0A14.927 14.927 0 008.57 21m0-8.57a6 6 0 118.56 0"/></svg>
                        </div>
                        <div>
                            <p class="font-semibold text-gray-900 text-[15px]">Primeros pasos</p>
                            <p class="text-sm text-gray-500">Completá estos pasos para que el bot empiece a funcionar</p>
                        </div>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <!-- Progreso -->
                        <span id="ob-progress-label"
                              class="text-sm font-semibold"
                              style="color:#fd5101"
                              data-done="<%= [ob_step1, ob_step2].count(true) %>">
                            <%= [ob_step1, ob_step2].count(true) %>/4 completados
                        </span>
                        <!-- Barra de progreso -->
                        <div class="hidden sm:block w-24 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                            <div id="ob-progress-bar"
                                 class="h-full rounded-full transition-all"
                                 style="background:#fd5101; width:<%= [ob_step1, ob_step2].count(true) * 25 %>%"></div>
                        </div>
                        <!-- Botón ver guía -->
                        <button onclick="showOnboarding()"
                                class="text-xs font-semibold px-3 py-1.5 rounded-lg border border-[#ffd0b8] text-[#fd5101] hover:bg-[#fff4ef] transition-colors">
                            Ver guía
                        </button>
                        <!-- Cerrar -->
                        <button onclick="hideChecklist()"
                                class="w-7 h-7 flex items-center justify-center rounded-lg text-gray-400 hover:bg-gray-100 hover:text-gray-600 transition-colors text-lg leading-none">
                            &times;
                        </button>
                    </div>
                </div>

                <!-- Pasos -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-gray-100">

                    <!-- Paso 1: Activar asistente -->
                    <div class="ob-step px-5 py-4 flex items-start gap-3 <%= ob_step1 ? 'ob-step-done' : '' %>">
                        <div class="ob-step-icon w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 border-2 mt-0.5
                                    <%= ob_step1 ? 'bg-green-50 border-green-200 text-green-600' : 'bg-orange-50 border-orange-200 text-[#fd5101]' %>">
                            <% if ob_step1 %>
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                            <% else %>
                                <span class="text-xs font-black">1</span>
                            <% end %>
                        </div>
                        <div class="min-w-0">
                            <p class="ob-step-label text-sm font-semibold text-gray-800">Activar el Asistente</p>
                            <p class="text-xs text-gray-400 mt-0.5">Encendé el toggle en <strong>Ajustes del bot</strong>.</p>
                            <% unless ob_step1 %>
                                <button onclick="scrollToToggle()" class="mt-2 text-xs font-semibold text-[#fd5101] hover:underline">Ir al toggle →</button>
                            <% end %>
                        </div>
                    </div>

                    <!-- Paso 2: Configurar prompts -->
                    <div class="ob-step px-5 py-4 flex items-start gap-3 <%= ob_step2 ? 'ob-step-done' : '' %>">
                        <div class="ob-step-icon w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 border-2 mt-0.5
                                    <%= ob_step2 ? 'bg-green-50 border-green-200 text-green-600' : 'bg-orange-50 border-orange-200 text-[#fd5101]' %>">
                            <% if ob_step2 %>
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                            <% else %>
                                <span class="text-xs font-black">2</span>
                            <% end %>
                        </div>
                        <div class="min-w-0">
                            <p class="ob-step-label text-sm font-semibold text-gray-800">Completar Instrucciones</p>
                            <p class="text-xs text-gray-400 mt-0.5">Escribí al menos el Saludo General.</p>
                            <% unless ob_step2 %>
                                <button onclick="scrollToPrompts()" class="mt-2 text-xs font-semibold text-[#fd5101] hover:underline">Ir a Instrucciones →</button>
                            <% end %>
                        </div>
                    </div>

                    <!-- Paso 3: Base de conocimiento -->
                    <div class="ob-step px-5 py-4 flex items-start gap-3" id="ob-step-rag">
                        <div class="ob-step-icon w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 border-2 mt-0.5
                                    bg-orange-50 border-orange-200 text-[#fd5101]">
                            <span class="text-xs font-black">3</span>
                        </div>
                        <div class="min-w-0">
                            <p class="ob-step-label text-sm font-semibold text-gray-800">Subir Documentos</p>
                            <p class="text-xs text-gray-400 mt-0.5">Subí documentos de tu tienda (PDF/DOCX).</p>
                            <button onclick="goToRag()" class="mt-2 text-xs font-semibold text-[#fd5101] hover:underline">Ir a Documentos →</button>
                        </div>
                    </div>

                    <!-- Paso 4: Sincronizar productos -->
                    <div class="ob-step px-5 py-4 flex items-start gap-3" id="ob-step-prods">
                        <div class="ob-step-icon w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 border-2 mt-0.5
                                    bg-orange-50 border-orange-200 text-[#fd5101]">
                            <span class="text-xs font-black">4</span>
                        </div>
                        <div class="min-w-0">
                            <p class="ob-step-label text-sm font-semibold text-gray-800">Sincronizar Productos</p>
                            <p class="text-xs text-gray-400 mt-0.5">Importá tu catálogo de MercadoLibre.</p>
                            <button onclick="goToProducts()" class="mt-2 text-xs font-semibold text-[#fd5101] hover:underline">Ir a Productos →</button>
                        </div>
                    </div>

                </div>
            </div>

            <!-- ===================== PANELES PRE-VENTA (form único) ===================== -->
            <form action="/dashboard/update" method="POST" class="space-y-6">
                <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

            <!-- ─── Panel: Ajustes del bot ─── -->
            <div id="panel-pv-ajustes" class="main-content">

                    <!-- Controles rápidos -->
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
                        <!-- Toggle bot -->
                        <div class="bg-white p-4 sm:p-6 rounded-2xl border border-gray-100 flex items-center justify-between gap-4 sm:gap-6">
                            <div>
                                <h3 class="font-semibold text-gray-800 text-lg">Estado del Asistente</h3>
                                <p class="text-[15px] text-gray-400 mt-1">El bot responderá automáticamente cuando esté activo.</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                                <input type="checkbox" name="chat_gpt_enabled" value="1" <%= 'checked' if @bot_enabled %> class="sr-only peer">
                                <div class="w-12 h-6 bg-gray-200 rounded-full peer
                                            peer-checked:bg-[#fd5101]
                                            after:content-[''] after:absolute after:top-0.5 after:left-[3px]
                                            after:bg-white after:rounded-full after:h-5 after:w-5
                                            after:transition-all peer-checked:after:translate-x-6
                                            after:shadow-sm"></div>
                            </label>
                        </div>

                        <!-- Retraso -->
                        <div class="bg-white p-4 sm:p-6 rounded-2xl border border-gray-100 flex items-center justify-between gap-4 sm:gap-6">
                            <div>
                                <h3 class="font-semibold text-gray-800 text-lg">Retraso de Respuesta</h3>
                                <p class="text-[15px] text-gray-400 mt-1">Segundos de pausa antes de enviar la respuesta.</p>
                            </div>
                            <div class="flex items-center gap-2 flex-shrink-0">
                                <input type="number" name="delay_seconds" value="<%= @delay_seconds %>"
                                    class="w-20 p-2.5 bg-gray-50 border border-gray-200 rounded-xl text-center font-bold text-lg focus-brand"
                                    style="color:#fd5101">
                                <span class="text-sm text-gray-400">seg</span>
                            </div>
                        </div>
                    </div>

                    <!-- Programación Horaria -->
                    <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                        <div class="px-4 sm:px-6 py-5 border-b border-gray-50">
                            <div class="flex items-center justify-between gap-3 flex-wrap">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:#fff4ef">
                                        <svg class="w-5 h-5" style="color:#fd5101" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold text-gray-800 text-lg">Programación Horaria</h3>
                                        <p class="text-[13px] text-gray-400">Múltiples franjas por día y excepciones para fechas específicas.</p>
                                    </div>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                                    <input type="checkbox" name="schedule[enabled]" value="1"
                                           id="schedule-toggle"
                                           <%= @schedule['enabled'] ? 'checked' : '' %>
                                           class="sr-only peer"
                                           onchange="toggleScheduleFields(this.checked)">
                                    <div class="w-12 h-6 bg-gray-200 rounded-full peer
                                                peer-checked:bg-[#fd5101]
                                                after:content-[''] after:absolute after:top-0.5 after:left-[3px]
                                                after:bg-white after:rounded-full after:h-5 after:w-5
                                                after:transition-all peer-checked:after:translate-x-6
                                                after:shadow-sm"></div>
                                </label>
                            </div>
                        </div>

                        <!-- Campos ocultos: el JS serializa aquí antes del submit -->
                        <input type="hidden" name="schedule[days_json]"      id="sched-days-json">
                        <input type="hidden" name="schedule[overrides_json]" id="sched-overrides-json">

                        <div id="schedule-fields" class="<%= @schedule['enabled'] ? '' : 'hidden' %>">
                            <!-- Info banner -->
                            <div class="px-4 sm:px-6 pt-5 pb-3">
                                <div id="schedule-info-banner" class="flex items-start gap-2.5 bg-blue-50 border border-blue-100 rounded-xl px-4 py-3">
                                    <svg class="w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                                    </svg>
                                    <div>
                                        <p class="text-[13px] text-blue-700 font-semibold">Con la programación activa, el estado general del bot es ignorado.</p>
                                        <p class="text-[12px] text-blue-600 mt-0.5">El bot responde solo en las franjas marcadas como <strong>Activo</strong>. Si la hora actual no está cubierta por ninguna franja, queda inactivo.</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Zona horaria -->
                            <div class="px-4 sm:px-6 pb-5">
                                <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5">Zona Horaria</label>
                                <select name="schedule[timezone]"
                                        class="w-full sm:w-72 bg-gray-50 border border-gray-200 rounded-xl px-3 py-2 text-sm text-gray-700 focus-brand">
                                    <% {
                                        'America/Argentina/Buenos_Aires' => 'Argentina (UTC-3)',
                                        'America/Montevideo'             => 'Uruguay (UTC-3)',
                                        'America/Sao_Paulo'              => 'Brasil (UTC-3)',
                                        'America/Santiago'               => 'Chile (UTC-4)',
                                        'America/Caracas'                => 'Venezuela (UTC-4)',
                                        'America/Lima'                   => 'Perú / Ecuador (UTC-5)',
                                        'America/Bogota'                 => 'Colombia (UTC-5)',
                                        'America/Mexico_City'            => 'México Central (UTC-6)',
                                        'America/New_York'               => 'USA Este (UTC-5)',
                                        'America/Los_Angeles'            => 'USA Oeste (UTC-8)',
                                        'Europe/Madrid'                  => 'España (UTC+1)',
                                        'UTC'                            => 'UTC'
                                    }.each do |tz_id, tz_label| %>
                                        <option value="<%= tz_id %>" <%= (@schedule['timezone'] || 'America/Argentina/Buenos_Aires') == tz_id ? 'selected' : '' %>><%= tz_label %></option>
                                    <% end %>
                                </select>
                            </div>

                            <!-- Builder renderizado por JS -->
                            <div id="schedule-builder" class="px-4 sm:px-6 pb-2"></div>

                            <!-- Excepciones por fecha -->
                            <div class="px-4 sm:px-6 pb-5">
                                <div class="flex items-center justify-between mb-3">
                                    <p class="text-xs font-bold text-gray-500 uppercase tracking-widest">Excepciones por Fecha</p>
                                    <button type="button" onclick="addOverride()"
                                            class="flex items-center gap-1 text-xs font-bold px-3 py-1.5 rounded-lg border border-[#ffd0b8] text-[#fd5101] hover:bg-[#fff4ef] transition-colors">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                                        Agregar excepción
                                    </button>
                                </div>
                                <div id="overrides-list" class="space-y-2"></div>
                                <p class="text-[11px] text-gray-400 mt-2">Las excepciones tienen prioridad sobre la programación semanal. Útil para feriados o días especiales.</p>
                            </div>

                            <!-- Advertencia -->
                            <div class="px-4 sm:px-6 pb-5">
                                <div id="schedule-warning" class="flex items-start gap-2 bg-amber-50 border border-amber-100 rounded-xl px-4 py-3">
                                    <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
                                    </svg>
                                    <p class="text-[12px] text-amber-700"><strong>Importante:</strong> Las horas dentro de un día no deben solaparse. Si una franja termina a las 08:00, la siguiente debe empezar a las 08:01. Los huecos sin cubrir dejan el bot inactivo.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end">
                        <button type="submit" class="px-6 py-2.5 rounded-xl text-sm font-bold text-white transition-colors" style="background:#fd5101">Guardar cambios</button>
                    </div>

                </div><!-- /panel-pv-ajustes -->

                <!-- ─── Panel: Instrucciones ─── -->
                <div id="panel-pv-instrucciones" class="main-content hidden">

                    <!-- Prompts -->
                    <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                        <div class="px-4 sm:px-6 py-5 border-b border-gray-50 flex items-center gap-3">
                            <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0"
                                 style="background:#fff4ef">
                                <svg class="w-5 h-5 text-[#fd5101]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-gray-800 text-lg">Entrenamiento — Prompts</h3>
                                <p class="text-[15px] text-gray-400">Define cómo debe comportarse el asistente en cada situación.</p>
                            </div>
                        </div>
                        <div class="divide-y divide-gray-50">
                            <% [
                                ['saludoGeneral',     'Saludo General',         'Cómo debe presentarse el bot al iniciar una conversación.'],
                                ['condicionProducto', 'Condición del Producto', 'Estado de los productos (nuevo, usado, reacondicionado).'],
                                ['precio',            'Precio',                 'Instrucciones sobre precios, descuentos y negociación.'],
                                ['envios',            'Envíos',                 'Políticas de envío, tiempos y costos.'],
                                ['garantia',          'Garantía',               'Condiciones de garantía y devoluciones.'],
                                ['mediosPago',        'Medios de Pago',         'Métodos de pago aceptados y cuotas.'],
                                ['otros',             'Otros',                  'Información adicional o instrucciones especiales.'],
                            ].each do |field, label, hint| %>
                                <div class="px-4 sm:px-6 py-5">
                                    <label class="block text-xs font-bold text-gray-500 mb-1 uppercase tracking-widest"><%= label %></label>
                                    <p class="text-[15px] text-gray-400 mb-2"><%= hint %></p>
                                    <textarea name="prompts[<%= field %>]" rows="3"
                                        class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus-brand text-[15px] leading-relaxed resize-none transition hover:border-gray-300"><%= @prompts[field] %></textarea>
                                </div>
                            <% end %>
                        </div>
                    </div>

                    <!-- ─── Instrucciones por Tipo de Envío ─── -->
                    <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                        <div class="px-4 sm:px-6 py-5 border-b border-gray-50 flex items-center gap-3">
                            <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:#fff4ef">
                                <svg class="w-5 h-5" style="color:#fd5101" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25m-10.5 0h10.5M8.25 18.75V14.25m0 4.5v-4.5m0 0H9.75M8.25 14.25H3.375m0 0V7.5A2.25 2.25 0 0 1 5.625 5.25h7.5A2.25 2.25 0 0 1 15.375 7.5v6.75"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-gray-800 text-lg">Instrucciones por Tipo de Envío</h3>
                                <p class="text-[13px] text-gray-400">El bot detecta el envío del ítem y usa la instrucción específica. Sin configurar, usa el prompt de <strong>Envíos</strong> como fallback.</p>
                            </div>
                        </div>
                        <div class="divide-y divide-gray-50">
                            <% [
                                ['fulfillment', '📦 Full (Fulfillment)',        'ML almacena, empaca y envía. Rapidez garantizada.',           '🟡 Amarillo ML'],
                                ['me2',         '🚐 MercadoEnvíos 2 (ME2)',     'ML retira el paquete en tu depósito.',                       '🔵 Azul ML'],
                                ['me1',         '🏪 MercadoEnvíos 1 (ME1)',     'El vendedor despacha en sucursal o correo.',                  '🟢 Verde ML'],
                                ['flex',        '⚡ Flex (mismo día)',           'El vendedor entrega en el día en zonas habilitadas.',         '🟣 Badge Flex'],
                                ['pickup',      '🏬 Retiro en local/punto',     'El comprador retira en tu domicilio o punto acordado.',       '⚫ Sin logística ML'],
                                ['custom',      '🔧 Envío personalizado',       'Tarifas y operativa propias del vendedor.',                   '⚪ Sin estándar ML'],
                            ].each do |key, label, hint, badge| %>
                                <div class="px-4 sm:px-6 py-5">
                                    <div class="flex items-start justify-between gap-2 mb-1 flex-wrap">
                                        <div>
                                            <label class="block text-xs font-bold text-gray-600 uppercase tracking-widest"><%= label %></label>
                                            <p class="text-[13px] text-gray-400 mt-0.5"><%= hint %> <span class="text-[11px] text-gray-300"><%= badge %></span></p>
                                        </div>
                                    </div>
                                    <textarea name="shipping_instructions[<%= key %>]" rows="2"
                                        placeholder="Dejar vacío para usar el prompt de Envíos como fallback…"
                                        class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus-brand text-[15px] leading-relaxed resize-none transition hover:border-gray-300"><%= @shipping_instructions[key] %></textarea>
                                </div>
                            <% end %>
                        </div>
                    </div>

                    <!-- ─── Aviso de Despacho ME1 ─── -->
                    <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                        <div class="px-4 sm:px-6 py-5 border-b border-gray-50">
                            <div class="flex items-center justify-between flex-wrap gap-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:#fff4ef">
                                        <svg class="w-5 h-5" style="color:#fd5101" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold text-gray-800 text-lg">Aviso de Despacho Automático</h3>
                                        <p class="text-[13px] text-gray-400">Mensaje al comprador cuando se confirma la venta. Aplica a todos los tipos de envío con <code class="text-xs bg-gray-100 px-1 py-0.5 rounded">cap_available ≥ 1</code>.</p>
                                    </div>
                                </div>
                                <!-- Toggle activar/desactivar -->
                                <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                                    <input type="checkbox" name="post_sale[enabled]" value="1"
                                           id="post-sale-toggle"
                                           <%= @post_sale['enabled'] ? 'checked' : '' %>
                                           class="sr-only peer"
                                           onchange="togglePostSaleFields(this.checked)">
                                    <div class="w-12 h-6 bg-gray-200 rounded-full peer
                                                peer-checked:bg-[#fd5101]
                                                after:content-[''] after:absolute after:top-0.5 after:left-[3px]
                                                after:bg-white after:rounded-full after:h-5 after:w-5
                                                after:transition-all peer-checked:after:translate-x-6
                                                after:shadow-sm"></div>
                                </label>
                            </div>
                        </div>

                        <div id="post-sale-fields" class="<%= @post_sale['enabled'] ? '' : 'hidden' %>">
                            <!-- Mensaje de despacho -->
                            <div class="px-4 sm:px-6 py-5 border-b border-gray-50">
                                <label class="block text-xs font-bold text-gray-500 mb-1 uppercase tracking-widest">Mensaje al despachar</label>
                                <p class="text-[13px] text-gray-400 mb-2">Se envía una única vez al comprador cuando el envío cambia a estado <code class="text-xs bg-gray-100 px-1 py-0.5 rounded">shipped</code> en MercadoLibre.</p>
                                <textarea name="post_sale[message]" rows="4"
                                    placeholder="Ej: ¡Hola! Te avisamos que tu pedido fue despachado hoy. Podés seguir el envío desde tu cuenta de MercadoLibre. ¡Muchas gracias por tu compra!"
                                    class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus-brand text-[15px] leading-relaxed resize-none transition hover:border-gray-300"><%= @post_sale['message'] %></textarea>
                            </div>
                            <!-- Restricciones ML -->
                            <div id="ml-restrictions" class="px-4 sm:px-6 py-4 bg-amber-50/60">
                                <p class="text-[13px] text-amber-700 font-semibold mb-1">⚠️ Restricciones del mensaje</p>
                                <ul class="text-[13px] text-amber-600 list-disc list-inside space-y-1">
                                    <li>Largo máximo: <strong>350 caracteres</strong>.</li>
                                    <li>No incluir links externos, teléfonos, emails ni referencias a otras tiendas.</li>
                                    <li>El mensaje puede ser moderado por ML si viola las políticas de comunicación.</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end">
                        <button type="submit" class="px-6 py-2.5 rounded-xl text-sm font-bold text-white transition-colors" style="background:#fd5101">Guardar cambios</button>
                    </div>

                </div><!-- /panel-pv-instrucciones -->

                <!-- ─── Panel: Saludos ─── -->
                <div id="panel-pv-saludos" class="main-content hidden">

                    <!-- ─── Saludos personalizados por Tienda Oficial ─── -->
                    <% if @official_stores.any? %>
                    <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                        <div class="px-4 sm:px-6 py-5 border-b border-gray-50">
                            <div class="flex items-center justify-between flex-wrap gap-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:#fff4ef">
                                        <svg class="w-5 h-5" style="color:#fd5101" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold text-gray-800 text-lg">Saludo por Tienda Oficial</h3>
                                        <p class="text-[13px] text-gray-400">Sin configurar, se usa el <strong>Saludo General</strong> como fallback.</p>
                                    </div>
                                </div>
                                <!-- Botón refrescar tiendas -->
                                <button type="button" id="btn-refresh-stores" onclick="refreshOfficialStores()"
                                        class="flex items-center gap-1.5 text-xs font-semibold px-3 py-2 rounded-lg border border-gray-200 text-gray-500 hover:border-[#ffd0b8] hover:text-[#fd5101] transition-colors">
                                    <svg id="refresh-icon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/>
                                    </svg>
                                    Refrescar tiendas
                                </button>
                            </div>
                        </div>
                        <div class="divide-y divide-gray-50" id="stores-list">
                            <% @official_stores.each do |store| %>
                                <div class="px-4 sm:px-6 py-5" id="store-row-<%= store.id %>">
                                    <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                                        <div class="flex items-center gap-3">
                                            <% if store.logo.present? %>
                                                <img src="<%= store.logo %>" alt="<%= store.name %>" class="w-10 h-10 rounded-lg object-contain border border-gray-100 bg-white p-0.5">
                                            <% else %>
                                                <div class="w-10 h-10 rounded-lg bg-gray-100 flex items-center justify-center text-gray-400">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18"/></svg>
                                                </div>
                                            <% end %>
                                            <div>
                                                <p class="text-sm font-bold text-gray-800"><%= store.name %></p>
                                                <p class="text-[11px] text-gray-400">ID: #<%= store.meli_store_id %></p>
                                            </div>
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[11px] font-bold
                                                         <%= store.status == 'active' ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-gray-100 text-gray-400 border border-gray-200' %>">
                                                <%= store.status == 'active' ? '● Activa' : '○ Inactiva' %>
                                            </span>
                                        </div>
                                        <button type="button" onclick="saveStoreGreeting(<%= store.id %>)"
                                                class="text-xs font-bold px-3 py-1.5 rounded-lg border border-[#ffd0b8] text-[#fd5101] hover:bg-[#fff4ef] transition-colors">
                                            Guardar
                                        </button>
                                    </div>
                                    <textarea id="store-greeting-<%= store.id %>" rows="3"
                                              placeholder="Dejar vacío para usar el Saludo General como fallback…"
                                              class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus-brand text-[15px] leading-relaxed resize-none transition hover:border-gray-300"><%= store.custom_greeting %></textarea>
                                    <p id="store-msg-<%= store.id %>" class="text-xs mt-1 hidden"></p>
                                </div>
                            <% end %>
                        </div>
                    </div>
                    <% end %>

                </div><!-- /panel-pv-saludos -->

            </form><!-- /form pre-venta -->

            <!-- ─── Panel: Documentos ─── -->
            <div id="panel-pv-docs" class="main-content hidden">
                <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">

                    <!-- Sub-tabs RAG -->
                    <div id="rag-tab-bar" class="flex border-b border-gray-100 bg-gray-50/50 overflow-x-auto">
                        <button onclick="switchRag(event, 'rag-global')"
                            class="rag-tab px-4 sm:px-6 py-4 text-sm font-medium text-gray-500 border-b-2 border-transparent transition-colors whitespace-nowrap">
                            🌎 Global
                        </button>
                        <button onclick="switchRag(event, 'rag-cats')"
                            class="rag-tab px-4 sm:px-6 py-4 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition-colors whitespace-nowrap">
                            📂 Categorías ML
                        </button>
                        <button onclick="switchRag(event, 'rag-prods')"
                            class="rag-tab px-4 sm:px-6 py-4 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition-colors flex items-center gap-2 whitespace-nowrap">
                            📦 Productos
                            <% if @is_syncing %>
                                <span id="sync-spinner" class="inline-block w-3 h-3 border-2 border-t-transparent rounded-full animate-spin"
                                      style="border-color:#fd5101; border-top-color:transparent"></span>
                            <% end %>
                        </button>
                    </div>

                    <div class="p-4 sm:p-6">
                        <!-- Global -->
                        <div id="rag-global" class="rag-content">
                        <div id="rag-global-card" class="flex justify-between items-start p-5 rounded-2xl border gap-4"
                                 style="background:#fff4ef; border-color:#ffd0b8">
                                <div>
                                    <h4 class="font-bold text-sm" style="color:#7a2500">Conocimiento de toda la Tienda</h4>
                                    <p class="text-xs mt-1" style="color:#b04020">Manuales de marca, políticas de envío, folletos generales.</p>
                                </div>
                                <%= render partial: 'doc_row', locals: { id: 'global', level: 'global', title: 'Global' } %>
                            </div>
                        </div>

                        <!-- Categorías -->
                        <div id="rag-cats" class="rag-content hidden space-y-4">
                            <% @master_categories.each do |mcat| %>
                                <div class="border border-gray-100 rounded-2xl p-4">
                                    <div class="flex justify-between items-center mb-3">
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <span class="cat-code-badge text-[11px] font-bold px-2 py-0.5 rounded-lg"
                                                  style="background:#fff4ef; color:#fd5101; border:1px solid #ffd0b8">
                                                <%= mcat.meli_category_id %>
                                            </span>
                                            <span class="text-xs font-black uppercase tracking-wide" style="color:#fd5101">
                                                <%= mcat.name %>
                                            </span>
                                        </div>
                                        <%= render partial: 'doc_row', locals: { id: mcat.meli_category_id, level: 'category', title: mcat.name } %>
                                    </div>
                                    <div class="space-y-2 ml-4">
                                        <% @sub_categories.where(parent_id: mcat.meli_category_id).each do |sub| %>
                                            <div class="bg-gray-50 p-3 rounded-xl flex justify-between items-center">
                                                <div class="flex items-center gap-2 flex-wrap">
                                                    <span class="sub-code-badge text-[11px] font-bold px-2 py-0.5 rounded-lg"
                                                          style="background:#f3f4f6; color:#6b7280; border:1px solid #e5e7eb">
                                                        <%= sub.meli_category_id %>
                                                    </span>
                                                    <span class="text-sm font-medium text-gray-600">↳ <%= sub.name %></span>
                                                </div>
                                                <%= render partial: 'doc_row', locals: { id: sub.meli_category_id, level: 'sub_category', title: sub.name } %>
                                            </div>
                                        <% end %>
                                    </div>
                                </div>
                            <% end %>
                        </div>

                        <!-- Productos -->
                        <div id="rag-prods" class="rag-content hidden">
                            <% if @is_syncing %>
                                <div id="sync-banner" class="py-16 text-center">
                                    <div class="animate-spin inline-block w-10 h-10 border-4 border-t-transparent rounded-full mb-4"
                                         style="border-color:#fd5101; border-top-color:transparent"></div>
                                    <p class="font-bold text-gray-600 text-sm">Sincronizando productos de MercadoLibre...</p>
                                    <p id="sync-count" class="text-xs text-gray-400 mt-1">Calculando...</p>
                                </div>
                                <div id="products-container"></div>
                            <% else %>
                                <div id="products-container">
                                    <%= render partial: 'products_table' %>
                                </div>
                            <% end %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══════════════ PANELES POST-VENTA ═══════════════ -->
            <form action="<%= update_post_venta_path %>" method="POST" class="space-y-6">
                <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

                <!-- ─── Panel: Ajustes del bot (Post-venta) ─── -->
                <div id="panel-postventa-ajustes" class="main-content hidden">

                    <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                        <div class="px-4 sm:px-6 py-5 border-b border-gray-50">
                            <div class="flex items-center justify-between flex-wrap gap-3">
                                <div>
                                    <h3 class="font-semibold text-gray-800 text-lg">Agente IA Post-Venta</h3>
                                    <p class="text-[13px] text-gray-400 mt-0.5">Respondé automáticamente los mensajes de compradores con pedidos en curso.</p>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                                    <input type="checkbox" name="post_venta_ia[enabled]" value="1"
                                           id="pv-ia-toggle"
                                           <%= @pv_ia['enabled'] != false ? 'checked' : '' %>
                                           class="sr-only peer">
                                    <div class="w-12 h-6 bg-gray-200 rounded-full peer
                                                peer-checked:bg-[#fd5101]
                                                after:content-[''] after:absolute after:top-0.5 after:left-[3px]
                                                after:bg-white after:rounded-full after:h-5 after:w-5
                                                after:transition-all peer-checked:after:translate-x-6
                                                after:shadow-sm"></div>
                                </label>
                            </div>
                        </div>
                        <div class="px-4 sm:px-6 py-5">
                            <label class="block text-xs font-bold text-gray-500 mb-1 uppercase tracking-widest">Modelo OpenAI</label>
                            <p class="text-[13px] text-gray-400 mb-3">
                                <code class="text-xs bg-gray-100 px-1 py-0.5 rounded">gpt-4o-mini</code> es más rápido y económico.
                                <code class="text-xs bg-gray-100 px-1 py-0.5 rounded">gpt-4o</code> da respuestas de mayor calidad para consultas complejas.
                            </p>
                            <div class="flex gap-4">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="post_venta_ia[model]" value="gpt-4o-mini"
                                           <%= (@pv_ia['model'] || 'gpt-4o-mini') == 'gpt-4o-mini' ? 'checked' : '' %>
                                           class="accent-[#fd5101]">
                                    <span class="text-sm text-gray-700 font-medium">gpt-4o-mini <span class="text-xs text-gray-400">(recomendado)</span></span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="post_venta_ia[model]" value="gpt-4o"
                                           <%= @pv_ia['model'] == 'gpt-4o' ? 'checked' : '' %>
                                           class="accent-[#fd5101]">
                                    <span class="text-sm text-gray-700 font-medium">gpt-4o</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end">
                        <button type="submit" class="px-6 py-2.5 rounded-xl text-sm font-bold text-white transition-colors" style="background:#fd5101">Guardar cambios</button>
                    </div>

                </div><!-- /panel-postventa-ajustes -->

                <!-- ─── Panel: Prompts (Post-venta) ─── -->
                <div id="panel-postventa-prompts" class="main-content hidden">

                    <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                        <div class="px-4 sm:px-6 py-5 border-b border-gray-50">
                            <label class="block text-xs font-bold text-gray-500 mb-1 uppercase tracking-widest">Tono e identidad del agente</label>
                            <p class="text-[13px] text-gray-400 mb-2">Describe cómo debe hablar el agente. Aplica a todas las ramas. Ej: <em>"Usar usted, tono formal, no usar emojis."</em></p>
                            <textarea name="post_venta_ia[prompts][tono]" rows="2"
                                placeholder="Ej: Usá un tono amigable y cercano, en español argentino. Dirigite siempre al cliente como 'vos'."
                                class="w-full p-3 bg-gray-50 border border-gray-200 rounded-xl focus-brand text-[14px] leading-relaxed resize-none transition hover:border-gray-300"><%= @pv_ia.dig('prompts', 'tono') %></textarea>
                        </div>

                        <div class="px-4 sm:px-6 py-5 space-y-5">
                            <p class="text-xs font-bold text-gray-500 uppercase tracking-widest">Comportamiento por tipo de consulta</p>

                            <!-- Logística -->
                            <div class="rounded-xl border border-gray-100 overflow-hidden">
                                <div class="px-4 py-3 intent-head-blue flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="text-base">🚚</span>
                                        <span class="font-semibold text-gray-800 text-sm">Logística</span>
                                        <span class="text-[12px] text-gray-400">tracking, envío, demoras</span>
                                    </div>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[logistica][enabled]" value="1"
                                               <%= @pv_ia.dig('logistica', 'enabled') != false ? 'checked' : '' %>
                                               class="sr-only peer"
                                               onchange="document.getElementById('pv-logistica-prompt').classList.toggle('hidden', !this.checked)">
                                        <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-[#fd5101] after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5 after:shadow-sm"></div>
                                    </label>
                                </div>
                                <div id="pv-logistica-prompt" class="px-4 py-3 <%= @pv_ia.dig('logistica', 'enabled') == false ? 'hidden' : '' %>">
                                    <label class="block text-xs text-gray-500 mb-1">Instrucciones adicionales para respuestas de envío</label>
                                    <textarea name="post_venta_ia[prompts][logistica]" rows="2"
                                        placeholder="Ej: Nuestros envíos demoran 2-5 días hábiles. No prometas fechas exactas."
                                        class="w-full p-2.5 bg-gray-50 border border-gray-200 rounded-lg focus-brand text-[13px] resize-none transition hover:border-gray-300"><%= @pv_ia.dig('prompts', 'logistica') %></textarea>
                                </div>
                            </div>

                            <!-- Soporte -->
                            <div class="rounded-xl border border-gray-100 overflow-hidden">
                                <div class="px-4 py-3 intent-head-purple flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="text-base">🔧</span>
                                        <span class="font-semibold text-gray-800 text-sm">Soporte técnico</span>
                                        <span class="text-[12px] text-gray-400">instrucciones, compatibilidad</span>
                                    </div>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[soporte][enabled]" value="1"
                                               <%= @pv_ia.dig('soporte', 'enabled') != false ? 'checked' : '' %>
                                               class="sr-only peer"
                                               onchange="document.getElementById('pv-soporte-fields').classList.toggle('hidden', !this.checked)">
                                        <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-[#fd5101] after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5 after:shadow-sm"></div>
                                    </label>
                                </div>
                                <div id="pv-soporte-fields" class="px-4 py-3 space-y-3 <%= @pv_ia.dig('soporte', 'enabled') == false ? 'hidden' : '' %>">
                                    <div>
                                        <label class="block text-xs text-gray-500 mb-1">Instrucciones adicionales para soporte</label>
                                        <textarea name="post_venta_ia[prompts][soporte]" rows="2"
                                            placeholder="Ej: El producto tiene 1 año de garantía. Para reclamos, pedí foto del defecto."
                                            class="w-full p-2.5 bg-gray-50 border border-gray-200 rounded-lg focus-brand text-[13px] resize-none transition hover:border-gray-300"><%= @pv_ia.dig('prompts', 'soporte') %></textarea>
                                    </div>
                                    <label class="flex items-center gap-2.5 cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[soporte][fallback_to_human]" value="1"
                                               <%= @pv_ia.dig('soporte', 'fallback_to_human') != false ? 'checked' : '' %>
                                               class="w-4 h-4 rounded accent-[#fd5101]">
                                        <span class="text-[13px] text-gray-700">Si la IA no encuentra solución, asignar automáticamente a agente humano (<code class="text-xs bg-gray-100 px-1 rounded">atencion-humana</code>)</span>
                                    </label>
                                </div>
                            </div>

                            <!-- Reclamo -->
                            <div class="rounded-xl border border-gray-100 overflow-hidden">
                                <div class="px-4 py-3 intent-head-red flex items-center">
                                    <div class="flex items-center gap-2">
                                        <span class="text-base">⚠️</span>
                                        <span class="font-semibold text-gray-800 text-sm">Reclamo</span>
                                        <span class="text-[12px] text-gray-400">daño, devolución, queja — siempre escala a humano</span>
                                    </div>
                                </div>
                                <div class="px-4 py-3 space-y-3">
                                    <label class="flex items-center gap-2.5 cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[reclamo][notify_customer]" value="1"
                                               <%= @pv_ia.dig('reclamo', 'notify_customer') ? 'checked' : '' %>
                                               class="w-4 h-4 rounded accent-[#fd5101]"
                                               onchange="document.getElementById('pv-escalacion-prompt').classList.toggle('hidden', !this.checked)">
                                        <span class="text-[13px] text-gray-700">Avisar al comprador que un especialista lo va a atender</span>
                                    </label>
                                    <div id="pv-escalacion-prompt" class="<%= @pv_ia.dig('reclamo', 'notify_customer') ? '' : 'hidden' %>">
                                        <label class="block text-xs text-gray-500 mb-1">Mensaje visible al cliente al escalar</label>
                                        <textarea name="post_venta_ia[prompts][escalacion]" rows="2"
                                            placeholder="Ej: Lamentamos el inconveniente. Un especialista de nuestro equipo te va a contactar en menos de 24hs."
                                            class="w-full p-2.5 bg-gray-50 border border-gray-200 rounded-lg focus-brand text-[13px] resize-none transition hover:border-gray-300"><%= @pv_ia.dig('prompts', 'escalacion') %></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Cierre -->
                            <div class="rounded-xl border border-gray-100 overflow-hidden">
                                <div class="px-4 py-3 intent-head-green flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="text-base">✅</span>
                                        <span class="font-semibold text-gray-800 text-sm">Cierre</span>
                                        <span class="text-[12px] text-gray-400">agradecimiento, todo bien, despedida</span>
                                    </div>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[cierre][enabled]" value="1"
                                               <%= @pv_ia.dig('cierre', 'enabled') != false ? 'checked' : '' %>
                                               class="sr-only peer"
                                               onchange="document.getElementById('pv-cierre-fields').classList.toggle('hidden', !this.checked)">
                                        <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-[#fd5101] after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5 after:shadow-sm"></div>
                                    </label>
                                </div>
                                <div id="pv-cierre-fields" class="px-4 py-3 space-y-3 <%= @pv_ia.dig('cierre', 'enabled') == false ? 'hidden' : '' %>">
                                    <div>
                                        <label class="block text-xs text-gray-500 mb-1">Instrucciones para el mensaje de despedida</label>
                                        <textarea name="post_venta_ia[prompts][cierre]" rows="2"
                                            placeholder="Ej: Invitá siempre a seguirnos en Instagram @tienda y a dejar una reseña en ML."
                                            class="w-full p-2.5 bg-gray-50 border border-gray-200 rounded-lg focus-brand text-[13px] resize-none transition hover:border-gray-300"><%= @pv_ia.dig('prompts', 'cierre') %></textarea>
                                    </div>
                                    <label class="flex items-center gap-2.5 cursor-pointer">
                                        <input type="checkbox" name="post_venta_ia[cierre][auto_resolve]" value="1"
                                               <%= @pv_ia.dig('cierre', 'auto_resolve') != false ? 'checked' : '' %>
                                               class="w-4 h-4 rounded accent-[#fd5101]">
                                        <span class="text-[13px] text-gray-700">Resolver conversación automáticamente al detectar cierre</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end pb-8">
                        <button type="submit" class="px-6 py-2.5 rounded-xl text-sm font-bold text-white transition-colors" style="background:#fd5101">Guardar cambios</button>
                    </div>

                </div><!-- /panel-postventa-prompts -->

            </form><!-- /form post-venta -->

            <!-- ─── Panel: Documentos Post-venta ─── -->
            <div id="panel-postventa-docs" class="main-content hidden">
                <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">

                    <!-- Sub-tabs RAG PV -->
                    <div id="pv-rag-tab-bar" class="flex border-b border-gray-100 bg-gray-50/50 overflow-x-auto">
                        <button onclick="switchPvRag(event, 'pv-rag-global')"
                            class="pv-rag-tab px-4 sm:px-6 py-4 text-sm font-medium text-gray-500 border-b-2 border-transparent transition-colors whitespace-nowrap">
                            🌎 Global
                        </button>
                        <button onclick="switchPvRag(event, 'pv-rag-cats')"
                            class="pv-rag-tab px-4 sm:px-6 py-4 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition-colors whitespace-nowrap">
                            📂 Categorías ML
                        </button>
                        <button onclick="switchPvRag(event, 'pv-rag-prods')"
                            class="pv-rag-tab px-4 sm:px-6 py-4 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition-colors whitespace-nowrap">
                            📦 Productos
                        </button>
                    </div>

                    <div class="p-4 sm:p-6">
                        <!-- Global -->
                        <div id="pv-rag-global" class="pv-rag-content">
                            <div id="pv-rag-global-card" class="flex justify-between items-start p-5 rounded-2xl border gap-4"
                                 style="background:#fff4ef; border-color:#ffd0b8">
                                <div>
                                    <h4 class="font-bold text-sm" style="color:#7a2500">Conocimiento Post-venta Global</h4>
                                    <p class="text-xs mt-1" style="color:#b04020">Políticas de devolución, garantías generales, instrucciones de uso comunes a todos tus productos.</p>
                                </div>
                                <%= render partial: 'pv_doc_row', locals: { id: 'global', level: 'global', title: 'Global' } %>
                            </div>
                        </div>

                        <!-- Categorías -->
                        <div id="pv-rag-cats" class="pv-rag-content hidden space-y-4">
                            <% @master_categories.each do |mcat| %>
                                <div class="border border-gray-100 rounded-2xl p-4">
                                    <div class="flex justify-between items-center mb-3">
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <span class="cat-code-badge text-[11px] font-bold px-2 py-0.5 rounded-lg"
                                                  style="background:#fff4ef; color:#fd5101; border:1px solid #ffd0b8">
                                                <%= mcat.meli_category_id %>
                                            </span>
                                            <span class="text-xs font-black uppercase tracking-wide" style="color:#fd5101">
                                                <%= mcat.name %>
                                            </span>
                                        </div>
                                        <%= render partial: 'pv_doc_row', locals: { id: mcat.meli_category_id, level: 'category', title: mcat.name } %>
                                    </div>
                                    <div class="space-y-2 ml-4">
                                        <% @sub_categories.where(parent_id: mcat.meli_category_id).each do |sub| %>
                                            <div class="bg-gray-50 p-3 rounded-xl flex justify-between items-center">
                                                <div class="flex items-center gap-2 flex-wrap">
                                                    <span class="sub-code-badge text-[11px] font-bold px-2 py-0.5 rounded-lg"
                                                          style="background:#f3f4f6; color:#6b7280; border:1px solid #e5e7eb">
                                                        <%= sub.meli_category_id %>
                                                    </span>
                                                    <span class="text-sm font-medium text-gray-600">↳ <%= sub.name %></span>
                                                </div>
                                                <%= render partial: 'pv_doc_row', locals: { id: sub.meli_category_id, level: 'sub', title: sub.name } %>
                                            </div>
                                        <% end %>
                                    </div>
                                </div>
                            <% end %>
                        </div>

                        <!-- Productos -->
                        <div id="pv-rag-prods" class="pv-rag-content hidden">
                            <% if @is_syncing %>
                                <div id="pv-sync-banner" class="py-16 text-center">
                                    <div class="animate-spin inline-block w-10 h-10 border-4 border-t-transparent rounded-full mb-4"
                                         style="border-color:#fd5101; border-top-color:transparent"></div>
                                    <p class="font-bold text-gray-600 text-sm">Sincronizando productos de MercadoLibre...</p>
                                    <p id="pv-sync-count" class="text-xs text-gray-400 mt-1">Calculando...</p>
                                </div>
                                <div id="pv-products-container"></div>
                            <% else %>
                                <div id="pv-products-container">
                                    <%= render partial: 'products_table', locals: { rag_partial: 'pv_doc_row', tab_param: 'pv-prods' } %>
                                </div>
                            <% end %>
                        </div>
                    </div>
                </div>
            </div><!-- /panel-postventa-docs -->

            <!-- ═══════════════ PANEL: IMPORTACIÓN MASIVA ═══════════════ -->
            <div id="panel-bulk-import" class="main-content hidden">
                <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 space-y-8">

                    <!-- Encabezado -->
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Importación Masiva desde Excel / CSV</h1>
                        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                            Subí un archivo con múltiples productos a la vez. Cada fila genera un documento RAG asociado al item de MercadoLibre correspondiente.
                        </p>
                    </div>

                    <!-- Paso 1: Subir archivo y detectar columnas -->
                    <div id="bulk-step-1" class="bg-white dark:bg-[#1c1e22] border border-gray-200 dark:border-gray-700 rounded-2xl p-6 space-y-4">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="flex-shrink-0 w-7 h-7 rounded-full bg-[#fd5101] text-white text-xs font-bold flex items-center justify-center">1</span>
                            <h2 class="text-base font-semibold text-gray-800 dark:text-gray-100">Seleccioná el archivo</h2>
                        </div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Formatos soportados: <strong>.xlsx</strong>, <strong>.xls</strong>, <strong>.csv</strong>. La primera fila debe contener los encabezados.</p>

                        <div class="flex gap-3 items-start flex-wrap">
                            <input type="file" id="bulk-file-input" accept=".csv,.xlsx,.xls"
                                   class="block text-sm text-gray-600 dark:text-gray-300 file:mr-3 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-medium file:bg-[#fd5101]/10 file:text-[#fd5101] hover:file:bg-[#fd5101]/20 cursor-pointer">
                            <button onclick="bulkUploadPreview()"
                                    class="py-2 px-5 bg-[#fd5101] text-white text-sm font-semibold rounded-xl hover:bg-orange-600 transition">
                                Detectar columnas
                            </button>
                        </div>
                        <div id="bulk-upload-status" class="hidden text-sm text-gray-500 dark:text-gray-400 italic"></div>
                    </div>

                    <!-- Paso 2: Mapeo de columnas (se muestra tras detectar) -->
                    <div id="bulk-step-2" class="hidden bg-white dark:bg-[#1c1e22] border border-gray-200 dark:border-gray-700 rounded-2xl p-6 space-y-5">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="flex-shrink-0 w-7 h-7 rounded-full bg-[#fd5101] text-white text-xs font-bold flex items-center justify-center">2</span>
                            <h2 class="text-base font-semibold text-gray-800 dark:text-gray-100">Mapeá las columnas</h2>
                        </div>

                        <div id="bulk-filename-badge" class="inline-flex items-center gap-2 text-xs bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-3 py-1.5 rounded-full font-medium"></div>

                        <!-- Selector de destino (pre o post venta) -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Base de conocimiento de destino</label>
                            <select id="bulk-mode" class="w-full sm:w-64 text-sm border border-gray-300 dark:border-gray-600 rounded-xl px-3 py-2 bg-white dark:bg-[#21242c] text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#fd5101]/40">
                                <option value="pre">Pre-venta (preguntas de compradores)</option>
                                <option value="pv">Post-venta (soporte, logística, reclamos)</option>
                            </select>
                        </div>

                        <!-- Columna item_id -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                Columna con el <strong>Item ID de MercadoLibre</strong> <span class="text-red-500">*</span>
                            </label>
                            <select id="bulk-item-id-col" class="w-full sm:w-64 text-sm border border-gray-300 dark:border-gray-600 rounded-xl px-3 py-2 bg-white dark:bg-[#21242c] text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#fd5101]/40">
                            </select>
                        </div>

                        <!-- Columnas de contenido -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                                Columnas que forman el <strong>contenido del documento</strong> <span class="text-red-500">*</span>
                                <span class="text-gray-400 font-normal">(seleccioná una o más)</span>
                            </label>
                            <div id="bulk-content-cols" class="grid grid-cols-2 sm:grid-cols-3 gap-2"></div>
                        </div>

                        <!-- Preview de filas -->
                        <div>
                            <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-2">Vista previa (primeras 3 filas)</p>
                            <div id="bulk-preview-table" class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700 text-xs"></div>
                        </div>

                        <!-- Submit -->
                        <form id="bulk-import-form" action="<%= bulk_import_path %>" method="POST">
                            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                            <input type="hidden" name="token" id="bulk-token">
                            <input type="hidden" name="item_id_col" id="bulk-hidden-item-id-col">
                            <input type="hidden" name="mode" id="bulk-hidden-mode">
                            <!-- content_cols se inyectan por JS antes del submit -->
                            <div id="bulk-content-cols-hidden"></div>

                            <button type="button" onclick="bulkSubmit()"
                                    class="mt-2 py-2.5 px-7 bg-[#fd5101] text-white text-sm font-bold rounded-xl hover:bg-orange-600 transition shadow-md">
                                Importar documentos
                            </button>
                        </form>
                    </div>

                    <!-- Nota informativa -->
                    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-2xl p-5">
                        <h3 class="text-sm font-semibold text-blue-800 dark:text-blue-300 mb-2">¿Cómo funciona?</h3>
                        <ul class="text-sm text-blue-700 dark:text-blue-400 space-y-1 list-disc list-inside">
                            <li>Cada fila del archivo genera un <strong>documento RAG separado</strong> asociado al item ID indicado.</li>
                            <li>Si el mismo item ID aparece en varias filas, se crean múltiples documentos para ese producto (la búsqueda devuelve los más relevantes).</li>
                            <li>Los embeddings se generan en segundo plano. Según el volumen puede tardar unos minutos.</li>
                            <li>Los documentos importados conviven con los cargados manualmente. Podés mezclar ambos métodos.</li>
                        </ul>
                    </div>

                </div>
            </div><!-- /panel-bulk-import -->

        </main>
    </div><!-- fin contenido principal -->
</div><!-- fin flex raíz -->

<!-- ═══════════════ MODAL ONBOARDING ═══════════════ -->
<div id="modal-onboarding"
     class="fixed inset-0 bg-gray-900/60 hidden items-center justify-center z-[100] p-4 backdrop-blur-sm">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg relative flex flex-col overflow-hidden"
         style="max-height:90vh">

        <!-- Barra de progreso superior -->
        <div class="h-1 bg-gray-100">
            <div id="ob-modal-bar" class="h-full rounded-full transition-all duration-300" style="background:#fd5101; width:20%"></div>
        </div>

        <!-- Slide 1 — Bienvenida -->
        <div class="ob-slide active flex-col items-center text-center px-6 py-8 sm:px-10 sm:py-10" id="obs-1">
            <!-- Logo animado -->
            <div class="w-20 h-20 rounded-2xl flex items-center justify-center mb-6 shadow-lg"
                 style="background:#fd5101">
                <svg width="44" height="44" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M85 8 L8 50 L36 60 L28 92 L54 68 L85 8 Z" stroke="white" stroke-width="10" stroke-linejoin="round" stroke-linecap="round" fill="none"/>
                    <line x1="85" y1="8" x2="36" y2="60" stroke="white" stroke-width="10" stroke-linecap="round"/>
                </svg>
            </div>
            <h2 class="text-2xl font-black text-gray-900 mb-3">Bienvenido a reply-ai</h2>
            <p class="text-[15px] text-gray-500 leading-relaxed max-w-sm">
                Tu asistente virtual para MercadoLibre. Configurá Pre-venta y Post-venta en cuatro pasos simples.
            </p>
            <div class="mt-8 w-full flex flex-col gap-3">
                <!-- Pre-venta -->
                <div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Pre-venta</p>
                    <div class="grid grid-cols-3 gap-2">
                        <div class="bg-gray-50 rounded-xl p-3 flex flex-col items-center gap-1.5">
                            <span class="text-xl">✍️</span>
                            <span class="text-[11px] font-semibold text-gray-500">Instrucciones</span>
                        </div>
                        <div class="bg-gray-50 rounded-xl p-3 flex flex-col items-center gap-1.5">
                            <span class="text-xl">📚</span>
                            <span class="text-[11px] font-semibold text-gray-500">Documentos</span>
                        </div>
                        <div class="bg-gray-50 rounded-xl p-3 flex flex-col items-center gap-1.5">
                            <span class="text-xl">🔛</span>
                            <span class="text-[11px] font-semibold text-gray-500">Activar</span>
                        </div>
                    </div>
                </div>
                <!-- Post-venta -->
                <div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Post-venta</p>
                    <div class="grid grid-cols-2 gap-2">
                        <div class="bg-gray-50 rounded-xl p-3 flex flex-col items-center gap-1.5">
                            <span class="text-xl">⚙️</span>
                            <span class="text-[11px] font-semibold text-gray-500">Configurar</span>
                        </div>
                        <div class="bg-gray-50 rounded-xl p-3 flex flex-col items-center gap-1.5">
                            <span class="text-xl">💬</span>
                            <span class="text-[11px] font-semibold text-gray-500">Prompts</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Slide 2 — Prompts + Retraso -->
        <div class="ob-slide flex-col px-6 py-6 sm:px-10 sm:py-8" id="obs-2">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4 flex-shrink-0"
                 style="background:#fff4ef">
                <svg class="w-7 h-7" fill="none" stroke="#fd5101" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
            </div>
            <span class="text-xs font-black uppercase tracking-widest mb-1" style="color:#fd5101">Paso 1 de 4</span>
            <h2 class="text-xl font-black text-gray-900 mb-3">Configurá las instrucciones del bot</h2>

            <!-- Instrucciones -->
            <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100 mb-3">
                <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#fd5101" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                    <p class="text-sm font-bold text-gray-700">Instrucciones — comportamiento del asistente</p>
                </div>
                <p class="text-xs text-gray-500 leading-relaxed mb-2">
                    Textos que le indican al bot <em>cómo debe responder</em> en cada tema. Encontrás esta sección en <strong class="text-gray-600">MercadoLibre → Pre-venta → Instrucciones</strong> en la barra lateral. Empezá por el <strong class="text-gray-600">Saludo General</strong>.
                </p>
                <p class="text-[11px] text-gray-400">💡 Cuanto más detallado sea el prompt, más preciso será el asistente.</p>
            </div>

            <!-- Retraso -->
            <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
                <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#fd5101" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <p class="text-sm font-bold text-gray-700">Retraso de Respuesta</p>
                </div>
                <p class="text-xs text-gray-500 leading-relaxed mb-2">
                    Define cuántos <strong class="text-gray-600">segundos espera</strong> el bot antes de enviar la respuesta. Esto hace que la interacción se sienta más natural y humana.
                </p>
                <div class="flex items-center gap-3">
                    <div class="flex items-center gap-1.5 bg-white border border-gray-200 rounded-xl px-3 py-1.5">
                        <span class="text-base font-black" style="color:#fd5101">3</span>
                        <span class="text-xs text-gray-400">seg</span>
                    </div>
                    <p class="text-[11px] text-gray-400">Recomendado: 30–60 segundos. Con 0 responde al instante.</p>
                </div>
            </div>

            <button onclick="closeOnboarding(); scrollToPrompts();"
                    class="mt-4 text-sm font-bold px-4 py-2 rounded-xl border border-[#ffd0b8] text-[#fd5101] hover:bg-[#fff4ef] transition-colors self-start">
                Ir a Instrucciones →
            </button>
        </div>

        <!-- Slide 3 — Base de Conocimiento -->
        <div class="ob-slide flex-col px-6 py-6 sm:px-10 sm:py-8" id="obs-3">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4 flex-shrink-0"
                 style="background:#fff4ef">
                <svg class="w-7 h-7" fill="none" stroke="#fd5101" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
            </div>
            <span class="text-xs font-black uppercase tracking-widest mb-1" style="color:#fd5101">Paso 2 de 4</span>
            <h2 class="text-xl font-black text-gray-900 mb-1">Entrenalo con tu información</h2>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">
                Subí archivos <strong class="text-gray-600">PDF, DOCX o TXT</strong> (máx. 10&nbsp;MB cada uno) y el bot los usará como fuente de respuestas.
            </p>

            <!-- Niveles de documentos -->
            <div class="space-y-2">

                <!-- Global -->
                <div class="flex items-start gap-3 bg-gray-50 rounded-xl p-3 border border-gray-100">
                    <span class="text-lg flex-shrink-0 mt-0.5">🌎</span>
                    <div class="min-w-0">
                        <p class="text-xs font-bold text-gray-700">Global <span class="font-normal text-gray-400">— aplica a toda la tienda</span></p>
                        <p class="text-[11px] text-gray-400 leading-relaxed">Políticas de envío, condiciones de garantía, medios de pago, FAQs generales, manual de marca.</p>
                    </div>
                </div>

                <!-- Categoría + Subcategoría -->
                <div class="flex items-start gap-3 bg-gray-50 rounded-xl p-3 border border-gray-100">
                    <span class="text-lg flex-shrink-0 mt-0.5">📂</span>
                    <div class="min-w-0">
                        <p class="text-xs font-bold text-gray-700">Categoría / Subcategoría <span class="font-normal text-gray-400">— por rubro</span></p>
                        <p class="text-[11px] text-gray-400 leading-relaxed">Documentos específicos de un rubro o sublínea: ficha técnica de celulares, guía de talles para ropa, instrucciones de instalación para electro, etc.</p>
                    </div>
                </div>

                <!-- Productos -->
                <div class="flex items-start gap-3 bg-gray-50 rounded-xl p-3 border border-gray-100">
                    <span class="text-lg flex-shrink-0 mt-0.5">📦</span>
                    <div class="min-w-0">
                        <p class="text-xs font-bold text-gray-700">Producto individual <span class="font-normal text-gray-400">— detalle de un ítem ML</span></p>
                        <p class="text-[11px] text-gray-400 leading-relaxed">Manual de uso, ficha técnica o hoja de datos de un producto concreto de tu catálogo de MercadoLibre.</p>
                    </div>
                </div>

            </div>

            <p class="text-[11px] text-gray-400 mt-3">💡 Los documentos más específicos tienen <strong class="text-gray-500">mayor prioridad</strong>: Producto > Subcategoría > Categoría > Global.</p>

            <button onclick="closeOnboarding(); goToRag();"
                    class="mt-4 text-sm font-bold px-4 py-2 rounded-xl border border-[#ffd0b8] text-[#fd5101] hover:bg-[#fff4ef] transition-colors self-start">
                Ir a Documentos →
            </button>
        </div>

        <!-- Slide 4 — Post-venta -->
        <div class="ob-slide flex-col px-6 py-6 sm:px-10 sm:py-8" id="obs-4">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4 flex-shrink-0"
                 style="background:#fff4ef">
                <svg class="w-7 h-7" fill="none" stroke="#fd5101" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/></svg>
            </div>
            <span class="text-xs font-black uppercase tracking-widest mb-1" style="color:#fd5101">Paso 3 de 4</span>
            <h2 class="text-xl font-black text-gray-900 mb-3">Configurá la IA Post-venta</h2>

            <!-- Activar IA Post-venta -->
            <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100 mb-3">
                <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#fd5101" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.636 5.636a9 9 0 1012.728 0M12 3v9"/></svg>
                    <p class="text-sm font-bold text-gray-700">Activar IA Post-venta</p>
                </div>
                <p class="text-xs text-gray-500 leading-relaxed">
                    Activá el toggle en <strong class="text-gray-600">MercadoLibre → Post-venta → Ajustes del bot</strong> para que el asistente gestione reclamos y consultas de posventa de forma automática.
                </p>
            </div>

            <!-- Prompts Post-venta -->
            <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
                <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#fd5101" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                    <p class="text-sm font-bold text-gray-700">Prompts de Post-venta</p>
                </div>
                <p class="text-xs text-gray-500 leading-relaxed">
                    En <strong class="text-gray-600">MercadoLibre → Post-venta → Prompts</strong> definí el tono y las respuestas para reclamos, logística, soporte y cierre de conversación.
                </p>
            </div>

            <button onclick="closeOnboarding(); showPanel('panel-postventa-ajustes');"
                    class="mt-4 text-sm font-bold px-4 py-2 rounded-xl border border-[#ffd0b8] text-[#fd5101] hover:bg-[#fff4ef] transition-colors self-start">
                Ir a Post-venta →
            </button>
        </div>

        <!-- Slide 5 — Activar -->
        <div class="ob-slide flex-col px-6 py-8 sm:px-10 sm:py-10" id="obs-5">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5 flex-shrink-0"
                 style="background:#fff4ef">
                <svg class="w-7 h-7" fill="none" stroke="#fd5101" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.636 5.636a9 9 0 1012.728 0M12 3v9"/></svg>
            </div>
            <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-black uppercase tracking-widest" style="color:#fd5101">Paso 4 de 4</span>
            </div>
            <h2 class="text-xl font-black text-gray-900 mb-3">¡Activá el Asistente!</h2>
            <p class="text-[15px] text-gray-500 leading-relaxed mb-6">
                Cuando hayas completado la configuración, activá los toggles correspondientes. <br><br>
                <strong class="text-gray-700">Pre-venta:</strong> <span class="text-gray-500">Estado del Asistente</span> en <strong class="text-gray-700">MercadoLibre → Pre-venta → Ajustes del bot</strong>.<br><br>
                <strong class="text-gray-700">Post-venta:</strong> <span class="text-gray-500">Estado de IA Post-venta</span> en <strong class="text-gray-700">MercadoLibre → Post-venta → Ajustes del bot</strong>.
            </p>
            <!-- Ilustración del toggle -->
            <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100 flex items-center justify-between">
                <div>
                    <p class="font-semibold text-gray-800 text-sm">Estado del Asistente</p>
                    <p class="text-xs text-gray-400">El bot responderá automáticamente.</p>
                </div>
                <div class="w-12 h-6 rounded-full flex items-center px-0.5 flex-shrink-0"
                     style="background:#fd5101">
                    <div class="w-5 h-5 rounded-full bg-white shadow-sm ml-auto"></div>
                </div>
            </div>
            <button onclick="closeOnboarding(); scrollToToggle();"
                    class="mt-5 text-sm font-bold px-4 py-2 rounded-xl border border-[#ffd0b8] text-[#fd5101] hover:bg-[#fff4ef] transition-colors self-start">
                Ir al toggle →
            </button>
        </div>

        <!-- Footer: dots + botones -->
        <div class="px-6 pb-6 sm:px-10 sm:pb-8 flex items-center justify-between flex-shrink-0">
            <!-- Dots -->
            <div class="flex items-center gap-2" id="ob-dots">
                <button class="ob-dot active" onclick="goToSlide(1)"></button>
                <button class="ob-dot" onclick="goToSlide(2)"></button>
                <button class="ob-dot" onclick="goToSlide(3)"></button>
                <button class="ob-dot" onclick="goToSlide(4)"></button>
                <button class="ob-dot" onclick="goToSlide(5)"></button>
            </div>

            <div class="flex items-center gap-2">
                <button id="ob-prev"
                        onclick="obPrev()"
                        class="px-4 py-2 rounded-xl text-sm font-semibold text-gray-500 hover:bg-gray-100 transition-colors hidden">
                    ← Anterior
                </button>
                <button id="ob-next"
                        onclick="obNext()"
                        class="px-6 py-2.5 rounded-xl text-sm font-black text-white transition-colors"
                        style="background:#fd5101"
                        onmouseover="this.style.background='#d94200'"
                        onmouseout="this.style.background='#fd5101'">
                    Empezar →
                </button>
                <button id="ob-done"
                        onclick="closeOnboarding()"
                        class="px-6 py-2.5 rounded-xl text-sm font-black text-white transition-colors hidden"
                        style="background:#fd5101"
                        onmouseover="this.style.background='#d94200'"
                        onmouseout="this.style.background='#fd5101'">
                    ¡Entendido! ✓
                </button>
            </div>
        </div>

        <!-- Botón cerrar (X) -->
        <button onclick="closeOnboarding()"
                class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full text-gray-400 hover:bg-gray-100 hover:text-gray-600 transition text-xl leading-none">
            &times;
        </button>
    </div>
</div>

<!-- ═══════════════ MODAL DE UPLOAD ═══════════════ -->
<div id="modal-upload" class="fixed inset-0 bg-gray-900/50 hidden items-center justify-center backdrop-blur-sm z-50 p-4">
    <div id="modal-panel" class="bg-white rounded-3xl p-5 sm:p-8 max-w-md w-full shadow-2xl">
        <div class="flex justify-between items-center mb-6">
            <h3 id="m-title" class="text-lg font-black text-gray-900"></h3>
            <button onclick="closeModal()" class="w-8 h-8 flex items-center justify-center rounded-full text-gray-400 hover:bg-gray-100 hover:text-gray-600 transition text-xl leading-none">&times;</button>
