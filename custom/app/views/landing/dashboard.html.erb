    // ── Post-venta toggle ─────────────────────────────────────────
    function togglePostSaleFields(enabled) {
        const fields = document.getElementById('post-sale-fields');
        if (enabled) fields.classList.remove('hidden');
        else         fields.classList.add('hidden');
    }

    // ── Programación Horaria ──────────────────────────────────────
    // Estado en memoria
    const SCHED_DAYS_INIT      = <%= ((@schedule['days']      || {}).to_json rescue '{}').html_safe %>;
    const SCHED_OVERRIDES_INIT = <%= ((@schedule['overrides'] || {}).to_json rescue '{}').html_safe %>;
    const DAY_NAMES = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
    // Orden de presentación: Lunes→Domingo
    const DAY_ORDER = [1,2,3,4,5,6,0];

    // schedDays: { "0": [{start,end,active}, ...], "1": [...], ... }
    // schedOverrides: { "2026-12-25": {mode:"always_on"|"always_off"}, ... }
    let schedDays      = Object.assign({}, SCHED_DAYS_INIT);
    let schedOverrides = Object.assign({}, SCHED_OVERRIDES_INIT);

    function toggleScheduleFields(on) {
        const fields = document.getElementById('schedule-fields');
        if (fields) fields.classList.toggle('hidden', !on);
    }

    // ── Renderizado del builder ────────────────────────────────
    function renderScheduleBuilder() {
        const builder = document.getElementById('schedule-builder');
        if (!builder) return;
        builder.innerHTML = '';

        DAY_ORDER.forEach(d => {
            const slots = schedDays[String(d)] || [];
            const dayDiv = document.createElement('div');
            dayDiv.className = 'mb-3 border border-gray-100 rounded-xl overflow-hidden';

            // Header del día
            const header = document.createElement('div');
            header.className = 'flex items-center justify-between px-4 py-2.5 bg-gray-50 border-b border-gray-100';
            header.innerHTML = `
                <span class="text-sm font-bold text-gray-700">${DAY_NAMES[d]}</span>
                <div class="flex items-center gap-1.5">
                    <button type="button" onclick="dayPreset(${d},'on')"
                            class="text-[10px] font-bold px-2 py-1 rounded-md border border-gray-200 text-gray-500 hover:border-[#ffd0b8] hover:text-[#fd5101] transition-colors">
                        Todo ON
                    </button>
                    <button type="button" onclick="dayPreset(${d},'off')"
                            class="text-[10px] font-bold px-2 py-1 rounded-md border border-gray-200 text-gray-500 hover:border-gray-400 transition-colors">
                        Todo OFF
                    </button>
                    <button type="button" onclick="dayPreset(${d},'clear')"
                            class="text-[10px] font-bold px-2 py-1 rounded-md border border-gray-200 text-gray-400 hover:border-red-200 hover:text-red-400 transition-colors">
                        Limpiar
                    </button>
                    <button type="button" onclick="addSlot(${d})"
                            class="text-[10px] font-bold px-2 py-1 rounded-md border border-[#ffd0b8] text-[#fd5101] hover:bg-[#fff4ef] transition-colors flex items-center gap-0.5">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                        Franja
                    </button>
                </div>`;
            dayDiv.appendChild(header);

            // Lista de franjas
            const slotList = document.createElement('div');
            slotList.className = 'px-4 py-2 space-y-2' + (slots.length === 0 ? ' pb-3' : '');
            slotList.id = `slots-day-${d}`;

            if (slots.length === 0) {
                slotList.innerHTML = '<p class="text-[12px] text-gray-400 py-1">Sin franjas configuradas — el bot está inactivo todo el día.</p>';
            } else {
                slots.forEach((slot, i) => {
                    slotList.appendChild(buildSlotRow(d, i, slot));
                });
            }
            dayDiv.appendChild(slotList);
            builder.appendChild(dayDiv);
        });
    }

    function buildSlotRow(d, i, slot) {
        const row = document.createElement('div');
        row.className = 'flex items-center gap-2 flex-wrap py-1.5 border-b border-gray-50 last:border-0';
        row.id = `slot-${d}-${i}`;

        const activeColor = slot.active ? '#fd5101' : '#9aa2b4';
        const activeBg    = slot.active ? '#fff4ef' : '#f3f4f6';
        const activeLabel = slot.active ? 'Activo' : 'Inactivo';

        row.innerHTML = `
            <input type="time" value="${slot.start}" oninput="updateSlot(${d},${i},'start',this.value)"
                   class="bg-gray-50 border border-gray-200 rounded-lg px-2 py-1.5 text-sm text-gray-700 focus-brand w-28">
            <span class="text-gray-400 text-xs">→</span>
            <input type="time" value="${slot.end}" oninput="updateSlot(${d},${i},'end',this.value)"
                   class="bg-gray-50 border border-gray-200 rounded-lg px-2 py-1.5 text-sm text-gray-700 focus-brand w-28">
            <button type="button" id="slot-btn-${d}-${i}"
                    onclick="toggleSlotActive(${d},${i})"
                    class="text-[11px] font-bold px-3 py-1.5 rounded-lg border transition-colors min-w-[76px]"
                    style="color:${activeColor}; background:${activeBg}; border-color:${slot.active ? '#ffd0b8' : '#e5e7eb'}">
                ${slot.active ? '🟢 ' : '⚫ '}${activeLabel}
            </button>
            <button type="button" onclick="removeSlot(${d},${i})"
                    class="w-6 h-6 flex items-center justify-center rounded-md text-gray-400 hover:bg-red-50 hover:text-red-400 transition-colors flex-shrink-0">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>`;
        return row;
    }

    function addSlot(d) {
        if (!schedDays[String(d)]) schedDays[String(d)] = [];
        // Default: empieza donde terminó el último slot, o en 00:00
        const prev = schedDays[String(d)].slice(-1)[0];
        const start = prev ? prev.end : '00:00';
        schedDays[String(d)].push({ start, end: start, active: true });
        renderScheduleBuilder();
    }

    function removeSlot(d, i) {
        schedDays[String(d)].splice(i, 1);
        renderScheduleBuilder();
    }

    function updateSlot(d, i, field, value) {
        if (schedDays[String(d)] && schedDays[String(d)][i]) {
            schedDays[String(d)][i][field] = value;
        }
    }

    function toggleSlotActive(d, i) {
        if (schedDays[String(d)] && schedDays[String(d)][i]) {
            schedDays[String(d)][i].active = !schedDays[String(d)][i].active;
            renderScheduleBuilder();
        }
    }

    function dayPreset(d, preset) {
        if (preset === 'on')    schedDays[String(d)] = [{ start: '00:00', end: '23:59', active: true  }];
        if (preset === 'off')   schedDays[String(d)] = [{ start: '00:00', end: '23:59', active: false }];
        if (preset === 'clear') schedDays[String(d)] = [];
        renderScheduleBuilder();
    }

    // ── Overrides ─────────────────────────────────────────────
    function renderOverrides() {
        const list = document.getElementById('overrides-list');
        if (!list) return;
        list.innerHTML = '';
        const keys = Object.keys(schedOverrides).sort();
        if (keys.length === 0) {
            list.innerHTML = '<p class="text-[12px] text-gray-400">Sin excepciones configuradas.</p>';
            return;
        }
        keys.forEach(dateStr => {
            const ov = schedOverrides[dateStr];
            const isOn = ov.mode === 'always_on';
            const label = isOn ? '🟢 Bot activo todo el día' : '⚫ Bot inactivo todo el día';
            const color = isOn ? '#fd5101' : '#6b7280';
            const bg    = isOn ? '#fff4ef' : '#f3f4f6';
            const border= isOn ? '#ffd0b8' : '#e5e7eb';

            const div = document.createElement('div');
            div.className = 'flex items-center gap-3 flex-wrap py-2 border-b border-gray-50 last:border-0';
            div.innerHTML = `
                <input type="date" value="${dateStr}"
                       onchange="updateOverrideDate('${dateStr}', this.value)"
                       class="bg-gray-50 border border-gray-200 rounded-lg px-2 py-1.5 text-sm text-gray-700 focus-brand">
                <button type="button" onclick="toggleOverrideMode('${dateStr}')"
                        class="text-[11px] font-bold px-3 py-1.5 rounded-lg border transition-colors"
                        style="color:${color}; background:${bg}; border-color:${border}">
                    ${label}
                </button>
                <button type="button" onclick="removeOverride('${dateStr}')"
                        class="w-6 h-6 flex items-center justify-center rounded-md text-gray-400 hover:bg-red-50 hover:text-red-400 transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>`;
            list.appendChild(div);
        });
    }

    function addOverride() {
        // Fecha de mañana como default
        const d = new Date(); d.setDate(d.getDate() + 1);
        const dateStr = d.toISOString().slice(0, 10);
        const key = schedOverrides[dateStr] ? Object.keys(schedOverrides).length + '_' + dateStr : dateStr;
        schedOverrides[dateStr] = { mode: 'always_on' };
        renderOverrides();
    }

    function removeOverride(dateStr) {
        delete schedOverrides[dateStr];
        renderOverrides();
    }

    function toggleOverrideMode(dateStr) {
        if (!schedOverrides[dateStr]) return;
        schedOverrides[dateStr].mode = schedOverrides[dateStr].mode === 'always_on' ? 'always_off' : 'always_on';
        renderOverrides();
    }

    function updateOverrideDate(oldDate, newDate) {
        if (!newDate || !schedOverrides[oldDate]) return;
        schedOverrides[newDate] = schedOverrides[oldDate];
        delete schedOverrides[oldDate];
        renderOverrides();
    }

    // ── Serializar antes del submit ────────────────────────────
    function serializeSchedule() {
        // Limpia días vacíos para no guardar arrays vacíos
        const cleanDays = {};
        Object.entries(schedDays).forEach(([d, slots]) => {
            if (slots && slots.length > 0) cleanDays[d] = slots;
        });
        const djInput = document.getElementById('sched-days-json');
        const ojInput = document.getElementById('sched-overrides-json');
        if (djInput) djInput.value = JSON.stringify(cleanDays);
        if (ojInput) ojInput.value = JSON.stringify(schedOverrides);
    }

    // ── Init on load ───────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        renderScheduleBuilder();
        renderOverrides();
        // Hook el form para serializar antes de submit
        const form = document.querySelector('form[action="/dashboard/update"]');
        if (form) form.addEventListener('submit', serializeSchedule);
    });

    // ── Tiendas Oficiales MercadoLibre ────────────────────────────
    function saveStoreGreeting(storeId) {
        const textarea = document.getElementById('store-greeting-' + storeId);
        const msgEl    = document.getElementById('store-msg-' + storeId);
        const greeting = textarea.value;

        fetch('/dashboard/stores/' + storeId + '/greeting', {
            method:  'PATCH',
            headers: {
                'Content-Type':     'application/json',
                'X-CSRF-Token':     document.querySelector('meta[name="csrf-token"]')?.content || '',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ greeting: greeting })
        })
        .then(r => r.json())
        .then(data => {
            if (data.ok) {
                msgEl.textContent = '✓ Guardado';
                msgEl.className   = 'text-xs mt-1 text-green-600';
            } else {
                msgEl.textContent = data.error || 'Error al guardar';
                msgEl.className   = 'text-xs mt-1 text-red-500';
            }
            msgEl.classList.remove('hidden');
            setTimeout(() => msgEl.classList.add('hidden'), 3000);
        })
        .catch(() => {
            msgEl.textContent = 'Error de red';
            msgEl.className   = 'text-xs mt-1 text-red-500';
            msgEl.classList.remove('hidden');
        });
    }

    function refreshOfficialStores() {
        const btn  = document.getElementById('btn-refresh-stores');
        const icon = document.getElementById('refresh-icon');
        btn.disabled = true;
        icon.classList.add('animate-spin');

        fetch('/dashboard/stores/refresh', {
            method:  'POST',
            headers: {
                'Content-Type':     'application/json',
                'X-CSRF-Token':     document.querySelector('meta[name="csrf-token"]')?.content || '',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(r => r.json())
        .then(() => {
            // Re-enable tras 3 segundos y recargar la página para mostrar tiendas nuevas
            setTimeout(() => {
                icon.classList.remove('animate-spin');
                btn.disabled = false;
                window.location.reload();
            }, 3000);
        })
        .catch(() => {
            icon.classList.remove('animate-spin');
            btn.disabled = false;
        });
    }

    // ══════════════════════════════════════════════════════════════════
    // IMPORTACIÓN MASIVA
    // ══════════════════════════════════════════════════════════════════

    // Variables de estado para el wizard
    let bulkColumns   = [];
    let bulkSampleRows = [];

    // PASO 1: sube el archivo y recibe las columnas detectadas
    function bulkUploadPreview() {
        const fileInput = document.getElementById('bulk-file-input');
        const statusEl  = document.getElementById('bulk-upload-status');

        if (!fileInput.files.length) {
            statusEl.textContent = 'Seleccioná un archivo primero.';
            statusEl.classList.remove('hidden');
            return;
        }

        const formData = new FormData();
        formData.append('file', fileInput.files[0]);

        statusEl.textContent = 'Analizando archivo…';
        statusEl.classList.remove('hidden');

        fetch('<%= bulk_import_preview_path %>', {
            method: 'POST',
            headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '<%= form_authenticity_token %>' },
            body: formData
        })
        .then(r => r.json())
        .then(data => {
            if (data.error) { statusEl.textContent = 'Error: ' + data.error; return; }

            bulkColumns    = data.columns || [];
            bulkSampleRows = data.sample_rows || [];

            document.getElementById('bulk-filename-badge').innerHTML =
                '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>'
                + data.filename;

            document.getElementById('bulk-token').value = data.token;

            // Llenar selector item_id
            const itemSel = document.getElementById('bulk-item-id-col');
            itemSel.innerHTML = bulkColumns.map(c =>
                `<option value="${c}">${c}</option>`
            ).join('');

            // Construir checkboxes para content_cols
            const colsDiv = document.getElementById('bulk-content-cols');
            colsDiv.innerHTML = bulkColumns.map(c => `
                <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300 cursor-pointer select-none">
                    <input type="checkbox" class="bulk-content-col-cb rounded border-gray-300 text-[#fd5101] focus:ring-[#fd5101]" value="${c}">
                    <span class="truncate">${c}</span>
                </label>
            `).join('');

            // Render tabla preview (máx 3 filas)
            bulkRenderPreview();

            statusEl.classList.add('hidden');
            document.getElementById('bulk-step-2').classList.remove('hidden');
            document.getElementById('bulk-step-2').scrollIntoView({ behavior: 'smooth', block: 'start' });
        })
        .catch(e => { statusEl.textContent = 'Error al analizar el archivo: ' + e.message; });
    }

    // Renderiza la tabla de preview con las columnas seleccionadas como contenido
    function bulkRenderPreview() {
        const itemCol     = document.getElementById('bulk-item-id-col')?.value;
        const checkedCols = [...document.querySelectorAll('.bulk-content-col-cb:checked')].map(c => c.value);
        const allCols     = itemCol ? [itemCol, ...checkedCols.filter(c => c !== itemCol)] : checkedCols;

        if (!bulkSampleRows.length || !allCols.length) {
            document.getElementById('bulk-preview-table').innerHTML = '<p class="p-3 text-gray-400 text-xs italic">Seleccioná las columnas para ver la vista previa.</p>';
            return;
        }

        const tableClass = 'w-full text-xs border-collapse';
        const thClass    = 'px-3 py-2 text-left font-semibold text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700';
        const tdClass    = 'px-3 py-2 text-gray-700 dark:text-gray-300 border-b border-gray-100 dark:border-gray-800 max-w-[160px] truncate';

        const headers = allCols.map(c => `<th class="${thClass}">${c}</th>`).join('');
        const rows = bulkSampleRows.slice(0, 3).map(row =>
            '<tr>' + allCols.map(c => `<td class="${tdClass}" title="${(row[c]||'').replace(/"/g,'&quot;')}">${row[c] || ''}</td>`).join('') + '</tr>'
        ).join('');

        document.getElementById('bulk-preview-table').innerHTML =
            `<table class="${tableClass}"><thead><tr>${headers}</tr></thead><tbody>${rows}</tbody></table>`;
    }

    // Escuchar cambios en los checkboxes para actualizar el preview
    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('bulk-content-col-cb') || e.target.id === 'bulk-item-id-col') {
            bulkRenderPreview();
        }
    });

    // PASO 2: construye los campos ocultos y hace submit del form
    function bulkSubmit() {
        const itemCol     = document.getElementById('bulk-item-id-col').value;
        const checkedCols = [...document.querySelectorAll('.bulk-content-col-cb:checked')].map(c => c.value);
        const mode        = document.getElementById('bulk-mode').value;
        const token       = document.getElementById('bulk-token').value;

        if (!itemCol) { alert('Seleccioná la columna de Item ID.'); return; }
        if (!checkedCols.length) { alert('Seleccioná al menos una columna de contenido.'); return; }

        document.getElementById('bulk-hidden-item-id-col').value = itemCol;
        document.getElementById('bulk-hidden-mode').value = mode;

        // Inyectar content_cols como inputs array
        const hiddenDiv = document.getElementById('bulk-content-cols-hidden');
        hiddenDiv.innerHTML = checkedCols.map(c =>
            `<input type="hidden" name="content_cols[]" value="${c.replace(/"/g, '&quot;')}">`
        ).join('');

        if (!confirm(`¿Confirmás la importación?\n\nItem ID: ${itemCol}\nColumnas de contenido: ${checkedCols.join(', ')}\nDestino: ${mode === 'pv' ? 'Post-venta' : 'Pre-venta'}\n\nLos documentos se generarán en segundo plano.`)) return;

        document.getElementById('bulk-import-form').submit();
    }
</script>
</body>
</html>
