<!DOCTYPE html>
<html lang="es" class="dark">
<head>
    <meta charset="UTF-8">
    <!-- Anti-FOUC: aplicar tema guardado ANTES del primer render -->
    <script>
        (function() {
            var saved = localStorage.getItem('replyai_theme');
            // Dark es el modo por defecto; solo cambia a light si el usuario lo eligió
            if (saved === 'light') {
                document.documentElement.className = 'light';
            } else {
                document.documentElement.className = 'dark';
            }
        })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/brand-assets/logo_reply-ai_thumbnail.png">
    <!-- Inter — misma tipografía que usa Chatwoot -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] },
                    /*
                     * Usamos la escala DEFAULT de Tailwind (base = 16 px),
                     * que es la misma que Chatwoot usa en su UI.
                     * xs=12  sm=14  base=16  lg=18  xl=20  2xl=24
                     */
                    colors: {
                        brand: {
                            DEFAULT: '#fd5101',
                            dark:    '#d94200',
                            light:   '#ff7c3f',
                            pale:    '#fff4ef',
                            border:  '#ffd0b8',
                        }
                    }
                }
            }
        }
    </script>
    <title>Panel de Control | Yobot</title>
    <style>
        /* ── Scrollbar ─────────────────────────────────────────── */
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 99px; }
        html.dark ::-webkit-scrollbar-thumb { background: #2d3139; }

        /* ── Focus ring ─────────────────────────────────────────── */
        .focus-brand:focus { outline: none; box-shadow: 0 0 0 3px rgba(253,81,1,.25); }

        /* ── Renderizado Inter (igual a Chatwoot) ───────────────── */
        body {
            font-feature-settings: 'kern' 1, 'liga' 1, 'calt' 1;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            font-size: 15px;   /* base Chatwoot real ≈ 15 px en la mayoría de sus vistas */
            line-height: 1.5;
        }

        /* ── Dark mode — paleta alineada a Chatwoot ───────────

           Chatwoot dark palette:
             bg-base    #151718   → fondo principal
             bg-surface #1c1e22   → cards, topbar
             bg-input   #21242c   → inputs, áreas anidadas
             border     #2d3139
             text-1     #ecedee
             text-2     #9aa2b4
             text-muted #6c737e
        ─────────────────────────────────────────────────────── */
        html.dark { color-scheme: dark; }
        html.dark body            { background-color: #151718 !important; color: #ecedee; }

        /* Superficies */
        html.dark .bg-white    { background-color: #1c1e22 !important; }
        html.dark .bg-gray-50  { background-color: #1e2025 !important; }
        html.dark .bg-gray-100 { background-color: #21242c !important; }

        /* Bordes */
        html.dark .border-gray-50  { border-color: #252830 !important; }
        html.dark .border-gray-100 { border-color: #2d3139 !important; }
        html.dark .border-gray-200 { border-color: #2d3139 !important; }
        html.dark .divide-gray-50 > * { border-color: #252830 !important; }

        /* Texto */
        html.dark .text-gray-900 { color: #ecedee !important; }
        html.dark .text-gray-800 { color: #e0e2e8 !important; }
        html.dark .text-gray-700 { color: #c4c9d4 !important; }
        html.dark .text-gray-600 { color: #9aa2b4 !important; }
        html.dark .text-gray-500 { color: #9aa2b4 !important; }
        html.dark .text-gray-400 { color: #6c737e !important; }
        html.dark .text-gray-300 { color: #3d4452 !important; }

        /* Inputs / textareas */
        html.dark textarea,
        html.dark input[type="number"],
        html.dark input[type="time"],
        html.dark select {
            background-color: #21242c !important;
            border-color: #2d3139 !important;
            color: #ecedee !important;
        }
        html.dark input[name="delay_seconds"] { color: #fd5101 !important; }

        /* Topbar */
        html.dark #topbar { background-color: #1c1e22 !important; border-bottom-color: #2d3139 !important; }
        html.dark #sidebar-toggle-mobile:hover { background-color: rgba(255,255,255,.08) !important; }
        html.dark #sidebar-toggle-mobile { color: #9aa2b4 !important; }

        /* RAG tab bar (bg-gray-50/50 usa CSS var de opacidad, esto lo fuerza) */
        html.dark #rag-tab-bar    { background-color: #1c1e22 !important; border-bottom-color: #2d3139 !important; }
        html.dark #pv-rag-tab-bar { background-color: #1c1e22 !important; border-bottom-color: #2d3139 !important; }

        /* Modal */
        html.dark #modal-panel { background-color: #1c1e22 !important; }

        /* Hover del toggle en dark */
        html.dark #theme-toggle:hover { background-color: #21242c !important; }

        /* ── Onboarding modal ───────────────────────────────── */
        #modal-onboarding { transition: opacity .2s ease; }

        .ob-slide { display: none; animation: obFadeIn .25s ease; }
        .ob-slide.active { display: flex; }

        @keyframes obFadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Dot nav */
        .ob-dot { width:8px; height:8px; border-radius:99px; background:#e5e7eb; transition: all .2s ease; cursor:pointer; }
        .ob-dot.active { width:24px; background:#fd5101; }

        html.dark #modal-onboarding .bg-white      { background-color: #1c1e22 !important; }
        html.dark #modal-onboarding .text-gray-900 { color: #ecedee !important; }
        html.dark #modal-onboarding .text-gray-500 { color: #9aa2b4 !important; }
        html.dark #modal-onboarding .bg-gray-50    { background-color: #21242c !important; }
        html.dark #modal-onboarding .border-gray-100 { border-color: #2d3139 !important; }
        html.dark #modal-onboarding .ob-dot        { background: #2d3139; }
        html.dark #modal-onboarding .ob-dot.active { background: #fd5101; }

        /* ── Checklist banner ───────────────────────────────── */
        .ob-step-done .ob-step-icon   { background: #ecfdf5; color: #16a34a; border-color: #bbf7d0; }
        .ob-step-done .ob-step-label  { text-decoration: line-through; color: #9aa2b4; }
        html.dark #onboarding-checklist                          { background-color: #1c1e22 !important; border-color: #2d3139 !important; }
        html.dark #ob-checklist-header                           { background: #21242c !important; border-color: #2d3139 !important; }
        html.dark #onboarding-checklist .border-gray-100         { border-color: #2d3139 !important; }
        html.dark #onboarding-checklist .divide-gray-100 > *     { border-color: #2d3139 !important; }
        /* Celdas de pasos */
        html.dark #onboarding-checklist .ob-step               { background-color: transparent !important; }
        /* Íconos de paso pendiente */
        html.dark #onboarding-checklist .ob-step-icon.bg-orange-50 { background-color: #2a1a0e !important; border-color: #5a2e10 !important; }
        /* Íconos de paso completado */
        html.dark #onboarding-checklist .ob-step-icon.bg-green-50  { background-color: #052e16 !important; border-color: #166534 !important; color: #4ade80 !important; }
        /* Textos */
        html.dark #onboarding-checklist .text-gray-800           { color: #e0e2e8 !important; }
        html.dark #onboarding-checklist .text-gray-400           { color: #6c737e !important; }
        /* Barra de progreso track */
        html.dark #onboarding-checklist .bg-gray-200             { background-color: #2d3139 !important; }
        /* Botón "Ver guía" */
        html.dark #onboarding-checklist .border-\[\#ffd0b8\]     { border-color: #5a2e10 !important; }
        html.dark #onboarding-checklist button.hover\:bg-gray-100:hover { background-color: #21242c !important; }

        /* ── RAG section dark mode ─────────────────────────── */
        /* Card Global: inline style con #fff4ef no puede ser sobreescrita por clase */
        html.dark #rag-global-card { background-color: #2a1a0e !important; border-color: #5a2e10 !important; }
        html.dark #rag-global-card h4 { color: #fb923c !important; }
        html.dark #rag-global-card p  { color: #c2723a !important; }
        /* Badges de código de categoría */
        html.dark #panel-pv-docs .cat-code-badge  { background: #2a1a0e !important; color: #fb923c !important; border-color: #5a2e10 !important; }
        html.dark #panel-pv-docs .sub-code-badge  { background: #21242c !important; color: #9aa2b4 !important; border-color: #2d3139 !important; }
        /* Tabla de productos: filas y cabecera */
        html.dark #panel-pv-docs table { border-color: #2d3139 !important; }
        html.dark #panel-pv-docs thead { background-color: #21242c !important; }
        html.dark #panel-pv-docs tbody tr.bg-white { background-color: #1c1e22 !important; }
        html.dark #panel-pv-docs tbody tr.bg-white:hover { background-color: #21242c !important; }
        html.dark #panel-pv-docs tbody tr.bg-gray-50 { background-color: #1e2025 !important; }
        html.dark #panel-pv-docs .divide-y > tr   { border-color: #2d3139 !important; }
        html.dark #panel-pv-docs .overflow-x-auto { border-color: #2d3139 !important; }
        /* Badges condición y estado en dark */
        html.dark #panel-pv-docs .bg-green-100 { background-color: #052e16 !important; color: #4ade80 !important; }
        html.dark #panel-pv-docs .bg-red-100   { background-color: #3b0a0a !important; color: #f87171 !important; }
        html.dark #panel-pv-docs .bg-blue-100  { background-color: #0f1e3a !important; color: #93c5fd !important; }
        html.dark #panel-pv-docs .bg-amber-100 { background-color: #2d1a00 !important; color: #fbbf24 !important; }
        /* Bg-gray-100 paginación */
        html.dark #panel-pv-docs .bg-gray-100  { background-color: #21242c !important; }
        /* Thumbnail bg blanco */
        html.dark #panel-pv-docs img.object-contain { background-color: #2d3139 !important; border-color: #3d4452 !important; }

        /* ── Panel post-venta docs (RAG PV) ────────────────── */
        html.dark #pv-rag-global-card { background-color: #2a1a0e !important; border-color: #5a2e10 !important; }
        html.dark #pv-rag-global-card h4 { color: #fb923c !important; }
        html.dark #pv-rag-global-card p  { color: #c2723a !important; }
        html.dark #panel-postventa-docs .cat-code-badge  { background: #2a1a0e !important; color: #fb923c !important; border-color: #5a2e10 !important; }
        html.dark #panel-postventa-docs .sub-code-badge  { background: #21242c !important; color: #9aa2b4 !important; border-color: #2d3139 !important; }
        html.dark #panel-postventa-docs table { border-color: #2d3139 !important; }
        html.dark #panel-postventa-docs thead { background-color: #21242c !important; }
        html.dark #panel-postventa-docs tbody tr.bg-white { background-color: #1c1e22 !important; }
        html.dark #panel-postventa-docs tbody tr.bg-white:hover { background-color: #21242c !important; }
        html.dark #panel-postventa-docs tbody tr.bg-gray-50 { background-color: #1e2025 !important; }
        html.dark #panel-postventa-docs .divide-y > tr   { border-color: #2d3139 !important; }
        html.dark #panel-postventa-docs .overflow-x-auto { border-color: #2d3139 !important; }
        html.dark #panel-postventa-docs .bg-green-100 { background-color: #052e16 !important; color: #4ade80 !important; }
        html.dark #panel-postventa-docs .bg-red-100   { background-color: #3b0a0a !important; color: #f87171 !important; }
        html.dark #panel-postventa-docs .bg-blue-100  { background-color: #0f1e3a !important; color: #93c5fd !important; }
        html.dark #panel-postventa-docs .bg-amber-100 { background-color: #2d1a00 !important; color: #fbbf24 !important; }
        html.dark #panel-postventa-docs .bg-gray-100  { background-color: #21242c !important; }
        html.dark #panel-postventa-docs img.object-contain { background-color: #2d3139 !important; border-color: #3d4452 !important; }

        /* ── Restricciones ML (post-venta) ─────────────────── */
        html.dark #ml-restrictions { background-color: #2a1a0e !important; }
        html.dark #ml-restrictions p { color: #fb923c !important; }
        html.dark #ml-restrictions ul { color: #c2723a !important; }
        html.dark #ml-restrictions strong { color: #fb923c !important; }
        html.dark #ml-restrictions code { background-color: #3d1e08 !important; color: #fb923c !important; }

        /* ── Programación Horaria dark mode ─────────────── */
        html.dark #schedule-info-banner { background-color: #0f1e3a !important; border-color: #1e3a5f !important; }
        html.dark #schedule-info-banner p { color: #93c5fd !important; }
        html.dark #schedule-info-banner strong { color: #bfdbfe !important; }
        html.dark #schedule-warning { background-color: #2a1a0e !important; border-color: #5a2e10 !important; }
        html.dark #schedule-warning p { color: #c2723a !important; }
        html.dark #schedule-warning strong { color: #fb923c !important; }
        html.dark #schedule-fields .border-gray-50 { border-color: #252830 !important; }
        html.dark #schedule-fields .border-gray-100 { border-color: #2d3139 !important; }

        /* ── Sidebar colapsable ─────────────────────────────── */
        #sidebar {
            width: 256px;
            transition: width .22s ease, transform .22s ease;
            overflow: hidden;
        }
        #sidebar.collapsed {
            width: 64px;
        }
        /* Ocultar textos y labels en modo colapsado */
        #sidebar.collapsed .sidebar-label,
        #sidebar.collapsed .sidebar-section-label,
        #sidebar.collapsed .sidebar-badge {
            display: none;
        }
        #sidebar.collapsed .sidebar-logo-text { display: none; }
        /* Centrar iconos cuando está colapsado */
        #sidebar.collapsed nav a,
        #sidebar.collapsed nav > div > div,
        #sidebar.collapsed .sidebar-user-link {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
        }
        #sidebar.collapsed nav a { gap: 0; }
        #sidebar.collapsed .sidebar-user-link { gap: 0; }
        #sidebar.collapsed #sidebar-logo-area { justify-content: center; padding-left: 0; padding-right: 0; }
        /* Canal colapsable: ocultar sub-items y centrar botón de canal */
        #sidebar.collapsed .sidebar-channel-btn { justify-content: center; padding-left: 0; padding-right: 0; gap: 0; }
        #sidebar.collapsed [id$="-items"] { display: none !important; }
        /* Tamaño de fuente de los desplegables de canal */
        .sidebar-channel-btn .sidebar-label { font-size: 13px !important; letter-spacing: 0.04em !important; }
        /* Mobile: oculto por defecto, overlay slide-in */
        @media (max-width: 767px) {
            #sidebar {
                position: fixed;
                left: 0; top: 0; bottom: 0;
                z-index: 50;
                width: 256px !important;
                transform: translateX(-100%);
            }
            #sidebar.mobile-open {
                transform: translateX(0);
            }
            #sidebar-overlay {
                display: none;
                position: fixed; inset: 0;
                background: rgba(0,0,0,.5);
                z-index: 49;
                backdrop-filter: blur(2px);
            }
            #sidebar-overlay.active { display: block; }
            #sidebar-toggle-desktop { display: none !important; }
        }
        @media (min-width: 768px) {
            #sidebar-toggle-mobile { display: none !important; }
            #sidebar-overlay { display: none !important; }
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 font-sans antialiased transition-colors duration-200">
<div class="flex h-screen overflow-hidden">

    <!-- ═══════════════ SIDEBAR ═══════════════ -->
    <!-- Overlay mobile -->
    <div id="sidebar-overlay" onclick="closeSidebar()"></div>
    <aside id="sidebar" class="flex-shrink-0 bg-[#0f1117] flex flex-col">

        <!-- Logo
             ══════════════════════════════════════════════
               LOGO  →  Reemplazá el bloque de texto por:
               <img src="/assets/reply-ai-logo.svg"
                    alt="Reply-AI" class="h-8 w-auto">
               (SVG o PNG con fondo transparente recomendado)
             ══════════════════════════════════════════════ -->
        <div id="sidebar-logo-area" class="relative h-16 flex-shrink-0 px-4 border-b border-white/10 flex items-center gap-3">
                <img src="/brand-assets/logo_reply-ai_thumbnail.png" alt="Reply-AI" class="h-6 w-auto flex-shrink-0">
                <span class="sidebar-logo-text text-white font-black text-lg tracking-wider">Yobot</span>
                <!-- Botón colapsar desktop (absolute para no afectar centrado del logo) -->
                <button id="sidebar-toggle-desktop" onclick="toggleSidebar()"
                        class="absolute right-2 top-1/2 -translate-y-1/2 w-7 h-7 flex items-center justify-center rounded-lg text-white/40 hover:text-white/80 hover:bg-white/10 transition"
                        title="Colapsar barra lateral">
                    <svg id="sb-chevron-left" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
                    <svg id="sb-chevron-right" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                </button>
        </div>

        <!-- Navegación principal -->
        <nav class="flex-1 px-3 py-5 overflow-y-auto space-y-1 overflow-x-hidden">

            <!-- ── Canal: MercadoLibre ── -->
            <div id="channel-meli">
                <!-- Header del canal (colapsable) -->
                <button onclick="toggleChannel('meli')"
                        class="sidebar-channel-btn w-full flex items-center gap-2.5 px-3 py-2 rounded-xl text-white/50 hover:text-white/80 hover:bg-white/5 transition-colors text-left">
                    <svg class="w-4 h-4 flex-shrink-0 text-[#ffe600]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
                    <span class="sidebar-label text-[11px] font-bold tracking-widest uppercase">MercadoLibre</span>
                    <svg id="meli-chevron" class="w-3 h-3 ml-auto flex-shrink-0 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
                </button>

                <div id="channel-meli-items" class="mt-0.5 space-y-3 pl-2">

                    <!-- Pre-venta -->
                    <div>
                        <p class="sidebar-section-label px-3 pt-2 pb-1 text-[9px] font-bold tracking-widest uppercase text-white/25">Pre-venta</p>
                        <ul class="space-y-0.5">
                            <li>
                                <a href="#" onclick="showPanel('panel-pv-ajustes'); return false;"
                                   class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-xl text-sm font-medium text-white/60 hover:text-white/90 hover:bg-white/10 transition-colors"
                                   data-panel="panel-pv-ajustes">
                                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
                                    <span class="sidebar-label">Ajustes del bot</span>
                                </a>
                            </li>
                            <li>
                                <a href="#" onclick="showPanel('panel-pv-instrucciones'); return false;"
                                   class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-xl text-sm font-medium text-white/60 hover:text-white/90 hover:bg-white/10 transition-colors"
                                   data-panel="panel-pv-instrucciones">
                                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                                    <span class="sidebar-label">Instrucciones</span>
                                </a>
                            </li>
                            <li>
                                <a href="#" onclick="showPanel('panel-pv-docs'); return false;"
