        "jsCode": "// Alternativa: reemplazar check_order_eligible por un Code node\nconst order = $json;\nconst statusOk = ['confirmed', 'paid'].includes(order.status);\nconst paymentOk = (order.payments ?? []).some(p => p.status === 'approved');\nif (!statusOk || !paymentOk) return [];\nreturn [{ json: order }];"
