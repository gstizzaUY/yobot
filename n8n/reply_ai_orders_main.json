    {
      "parameters": {
        "jsCode": "const order = $('get_order_details').item.json;\n// Si no tiene pack_id, usamos el order_id como identificador del pack\nconst packId = order.pack_id ?? order.id;\nconst sellerId = $('get_order_account_details').item.json.ml_user_id;\nconst buyerId = order.buyer.id;\nconst message = JSON.parse($('get_order_account_details').item.json.post_sale).message;\n\nreturn [{ json: { packId, sellerId, buyerId, message, orderId: order.id } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1792,
        -192
      ],
      "id": "57a40310-3a86-463b-b96c-2f75978ce7f1",
      "name": "get_pack_id"
    },
    {
      "parameters": {
        "jsCode": "const options = $('get_action_guide').item.json.options ?? [];\nconst other = options.find(o => o.id === 'OTHER');\nconst cap = other?.cap_available ?? 0;\nreturn [{ json: { cap } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
