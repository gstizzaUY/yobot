        "query": "INSERT INTO meli_orders (\n  account_id, ml_order_id, ml_buyer_id, item_id, \n  pack_id, order_status, shipping_mode, message_sent, created_at, updated_at\n)\nVALUES (\n  {{ $('get_order_account_details').item.json.chatwoot_account_id }},\n  '{{ $('get_order_details').item.json.id }}',\n  '{{ $('get_order_details').item.json.buyer.id }}',\n  '{{ $('get_order_details').item.json.order_items[0].item.id }}',\n  {{ $('get_order_details').item.json.pack_id !== null ? \"'\" + $('get_order_details').item.json.pack_id + \"'\" : 'NULL' }},\n  '{{ $('get_order_details').item.json.status }}',\n  '{{ $('get_order_details').item.json.shipping?.logistic_type }}',\n  false,\n  NOW(), NOW()\n)\nON CONFLICT (account_id, ml_order_id) DO NOTHING;",
